<section class="tab-content {{tab.cssClass}}" data-tab="equipment" data-group="primary">

  {{!-- ═══ PAPERDOLL ═══ --}}
  <div class="paperdoll">
    <div class="paperdoll-grid">

      {{!-- Top-Left: Main Hand --}}
      <div class="paperdoll-slot weapon-card {{#unless equippedWeapon}}empty-slot{{/unless}}" data-slot="mainhand">
        <div class="slot-label">Main Hand</div>
        {{#if equippedWeapon}}
        <div class="slot-card-inner" data-item-id="{{equippedWeapon.id}}">
          <img src="{{equippedWeapon.img}}" class="slot-img" width="40" height="40" data-action="postItemToChat" title="Post to chat" />
          <div class="slot-info">
            <span class="slot-name" data-action="editItem">{{equippedWeapon.name}}</span>
            <span class="slot-stats">Mt {{equippedWeapon.system.might}} | Crit {{equippedWeapon.system.crit}}{{#if mainhandIs2H}} | <strong>2H</strong>{{/if}}</span>
          </div>
          <a class="slot-unequip" data-action="toggleEquip" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
        {{else}}
        <div class="slot-empty-state">
          <i class="fas fa-sword"></i>
          <span>Unarmed</span>
        </div>
        {{/if}}
      </div>

      {{!-- Top-Right: Off Hand --}}
      <div class="paperdoll-slot offhand-card {{#unless equippedOffhand}}empty-slot{{/unless}}{{#if mainhandIs2H}} slot-disabled{{/if}}" data-slot="offhand">
        <div class="slot-label">Off Hand{{#if mainhandIs2H}} <small>(2H equipped)</small>{{/if}}</div>
        {{#if equippedOffhand}}
        <div class="slot-card-inner" data-item-id="{{equippedOffhand.id}}">
          <img src="{{equippedOffhand.img}}" class="slot-img" width="40" height="40" data-action="postItemToChat" title="Post to chat" />
          <div class="slot-info">
            <span class="slot-name" data-action="editItem">{{equippedOffhand.name}}</span>
            <span class="slot-stats">
              {{#if equippedOffhand.system.block}}Blk {{equippedOffhand.system.block}}{{else}}Mt {{equippedOffhand.system.might}}{{/if}}
              | Wt {{equippedOffhand.system.weight}}
            </span>
          </div>
          <a class="slot-unequip" data-action="unequipOffhand" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
        {{else}}
        <div class="slot-empty-state">
          <i class="fas fa-shield-halved"></i>
          <span>None</span>
        </div>
        {{/if}}
      </div>

      {{!-- Center: Actor Portrait --}}
      <div class="paperdoll-portrait">
        <img src="{{actor.img}}" alt="{{actor.name}}"
             style="object-position: {{system.portraitOffsetX}}% {{system.portraitOffsetY}}%;{{#if system.portraitMirrored}} transform: scaleX(-1);{{/if}}" />
      </div>

      {{!-- Middle-Left: Accessory 1 --}}
      {{#if accessorySlots}}
      <div class="paperdoll-slot paperdoll-accessory-slot {{#unless accessorySlots.[0]}}empty-slot{{/unless}}" data-slot="accessory" data-slot-index="0">
        <div class="slot-label">Accessory</div>
        {{#if accessorySlots.[0]}}
        <div class="slot-card-inner" data-item-id="{{accessorySlots.[0].id}}">
          <img src="{{accessorySlots.[0].img}}" class="slot-img" width="32" height="32" data-action="postItemToChat" title="Post to chat" />
          <div class="slot-info">
            <span class="slot-name" data-action="editItem">{{accessorySlots.[0].name}}</span>
          </div>
          <a class="slot-unequip" data-action="toggleEquip" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
        {{else}}
        <div class="slot-empty-state">
          <i class="fas fa-ring"></i>
          <span>Empty</span>
        </div>
        {{/if}}
      </div>
      {{/if}}

      {{!-- Middle-Right: Armor --}}
      <div class="paperdoll-slot armor-card {{#unless equippedArmor}}empty-slot{{/unless}}" data-slot="armor">
        <div class="slot-label">Armor</div>
        {{#if equippedArmor}}
        <div class="slot-card-inner" data-item-id="{{equippedArmor.id}}">
          <img src="{{equippedArmor.img}}" class="slot-img" width="40" height="40" data-action="postItemToChat" title="Post to chat" />
          <div class="slot-info">
            <span class="slot-name" data-action="editItem">{{equippedArmor.name}}</span>
            <span class="slot-stats">PDEF {{equippedArmor.system.pdef}} | MDEF {{equippedArmor.system.mdef}}</span>
          </div>
          <a class="slot-unequip" data-action="toggleEquip" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
        {{else}}
        <div class="slot-empty-state">
          <i class="fas fa-shirt"></i>
          <span>None</span>
        </div>
        {{/if}}
      </div>

      {{!-- Bottom-Left: Accessory 2 --}}
      {{#if accessorySlots.[1]}}
      <div class="paperdoll-slot paperdoll-accessory-slot" data-slot="accessory" data-slot-index="1">
        <div class="slot-label">Accessory</div>
        <div class="slot-card-inner" data-item-id="{{accessorySlots.[1].id}}">
          <img src="{{accessorySlots.[1].img}}" class="slot-img" width="32" height="32" data-action="postItemToChat" title="Post to chat" />
          <div class="slot-info">
            <span class="slot-name" data-action="editItem">{{accessorySlots.[1].name}}</span>
          </div>
          <a class="slot-unequip" data-action="toggleEquip" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
      </div>
      {{else}}
      <div class="paperdoll-slot paperdoll-accessory-slot empty-slot" data-slot="accessory" data-slot-index="1">
        <div class="slot-label">Accessory</div>
        <div class="slot-empty-state">
          <i class="fas fa-ring"></i>
          <span>Empty</span>
        </div>
      </div>
      {{/if}}

      {{!-- Bottom-Right: Bonus Accessory Slots (if any) --}}
      {{#each accessorySlots}}
      {{#if (gt @index 1)}}
      <div class="paperdoll-slot paperdoll-accessory-slot {{#unless this}}empty-slot{{/unless}}" data-slot="accessory" data-slot-index="{{@index}}">
        <div class="slot-label">Accessory {{math @index "+" 1}}</div>
        {{#if this}}
        <div class="slot-card-inner" data-item-id="{{this.id}}">
          <img src="{{this.img}}" class="slot-img" width="32" height="32" data-action="postItemToChat" title="Post to chat" />
          <div class="slot-info">
            <span class="slot-name" data-action="editItem">{{this.name}}</span>
          </div>
          <a class="slot-unequip" data-action="toggleEquip" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
        {{else}}
        <div class="slot-empty-state">
          <i class="fas fa-ring"></i>
          <span>Empty</span>
        </div>
        {{/if}}
      </div>
      {{/if}}
      {{/each}}

    </div>
  </div>

  {{!-- ═══ SPECIES ═══ --}}
  {{#if equippedSpecies}}
  <div class="species-display" data-item-id="{{equippedSpecies.id}}">
    <img src="{{equippedSpecies.img}}" class="species-display-img" width="24" height="24" data-action="editItem" />
    <span class="species-display-name" data-action="editItem">{{equippedSpecies.name}}</span>
    <span class="species-display-size">Size {{equippedSpecies.system.size}}</span>
  </div>
  {{/if}}

  {{!-- ═══ WEIGHT BAR ═══ --}}
  <div class="weight-bar-section">
    <div class="weight-bar-label">
      <span>Weight</span>
      <span class="weight-bar-values {{#if system.overencumbered}}overencumbered{{/if}}">{{system.totalWeight}} / {{system.carryingCapacity}}</span>
    </div>
    <div class="weight-bar-track">
      <div class="weight-bar-fill {{#if system.overencumbered}}overencumbered{{/if}}"
           style="width: {{#if system.carryingCapacity}}{{math system.totalWeight "/" system.carryingCapacity "*" 100}}%{{else}}0%{{/if}}"></div>
    </div>
    <div class="weight-breakdown">
      {{#if system.weightBreakdown.weapon}}<span class="wb-item">Wpn: {{system.weightBreakdown.weapon}}</span>{{/if}}
      {{#if system.weightBreakdown.offhand}}<span class="wb-item">Off: {{system.weightBreakdown.offhand}}</span>{{/if}}
      {{#if system.weightBreakdown.armor}}<span class="wb-item">Arm: {{system.weightBreakdown.armor}}</span>{{/if}}
      {{#if system.overencumbered}}<span class="wb-item capacity-warning">Capacity reached</span>{{/if}}
    </div>
  </div>

  {{!-- ═══ NATURAL WEAPONS ═══ --}}
  {{#if naturalWeapons.length}}
  <div class="inventory-divider"></div>
  <div class="natural-weapons-section">
    <h3><i class="fas fa-paw"></i> Natural Weapons</h3>
    <div class="adv-tile-grid">
      {{#each naturalWeapons}}
      <details class="adv-tile" data-item-id="{{this.id}}">
        <summary>
          <img src="{{this.img}}" class="adv-tile-img" data-action="editItem" />
          <span class="adv-tile-name">{{this.name}}</span>
          <a class="adv-tile-action attack-button" data-action="rollNaturalAttack" title="Attack"><i class="fas fa-dice-d20"></i></a>
        </summary>
        <div class="adv-tile-details">
          <div class="adv-tile-stats">
            <span class="adv-tile-stat">Mt {{this.system.might}}</span>
            <span class="adv-tile-stat">Crit {{this.system.crit}}</span>
          </div>
        </div>
      </details>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- ═══ INVENTORY ═══ --}}
  <div class="inventory-divider"></div>
  <div class="inventory-section">
    <div class="inventory-header">
      <h3>Inventory
        <a class="item-control add-item" data-action="addItem" data-type="weapon"><i class="fas fa-sword" title="Add Weapon"></i></a>
        <a class="item-control add-item" data-action="addItem" data-type="armor"><i class="fas fa-shield-halved" title="Add Armor"></i></a>
        <a class="item-control add-item" data-action="addItem" data-type="accessory"><i class="fas fa-ring" title="Add Accessory"></i></a>
        <a class="item-control add-item" data-action="addItem" data-type="consumable"><i class="fas fa-flask" title="Add Consumable"></i></a>
        {{#if hasSpatialInventory}}
        <a class="item-control spatial-inv-btn" data-action="openSpatialInventory" title="Spatial Inventory"><i class="fas fa-box-open"></i></a>
        {{/if}}
      </h3>
      <div class="eiress-wallet">
        <i class="fas fa-coins eiress-wallet-icon"></i>
        <span class="eiress-wallet-label">Eiress</span>
        <button type="button" class="eiress-wallet-btn" data-action="adjustEiress" data-delta="-1"><i class="fas fa-minus"></i></button>
        <input type="number" name="system.eiress" value="{{system.eiress}}" min="0" data-dtype="Number" class="eiress-wallet-value" />
        <button type="button" class="eiress-wallet-btn" data-action="adjustEiress" data-delta="1"><i class="fas fa-plus"></i></button>
      </div>
    </div>
    {{#if inventory.length}}
    <div class="adv-tile-grid">
      {{#each inventory}}
      <details class="adv-tile draggable {{#if this._isGranted}}granted-item{{/if}}" data-item-id="{{this.id}}" data-item-type="{{this.type}}">
        <summary>
          <img src="{{this.img}}" class="adv-tile-img" data-action="postItemToChat" title="Post to chat" />
          <span class="adv-tile-name">{{this.name}}</span>
          {{#if this.system.quantity}}<span class="adv-tile-badge">x{{this.system.quantity}}</span>{{/if}}
          {{#if ../hasSpatialInventory}}<a class="stow-spatial" data-action="stowInSpatial" title="Stow in Spatial Inventory"><i class="fas fa-box-archive"></i></a>{{/if}}
        </summary>
        <div class="adv-tile-details">
          <div class="adv-tile-stats">
            <span class="adv-tile-stat">{{this.type}}</span>
          </div>
        </div>
      </details>
      {{/each}}
    </div>
    {{else}}
    <div class="adv-empty-state"><em>No items in inventory.</em></div>
    {{/if}}
  </div>

</section>