<section class="tab-content {{tab.cssClass}}" data-tab="equipment">

  {{!-- ═══ PAPERDOLL ═══ --}}
  <div class="ms-section">
    <div class="ms-section-header equip"><div class="sh-gem"></div>Equipment</div>

    <div class="ms-paperdoll">

      {{!-- ── Armor (top) ── --}}
      <div class="ms-pd-slot armor-card {{#if equippedArmor}}filled{{else}}empty{{/if}}" data-slot="armor">
        <div class="ms-pd-label">Armor</div>
        {{#if equippedArmor}}
        <div class="slot-card-inner" data-item-id="{{equippedArmor.id}}">
          <div class="ms-pd-icon">
            <img src="{{equippedArmor.img}}" data-action="postItemToChat" />
          </div>
          <span class="ms-pd-item-name" data-action="editItem">{{equippedArmor.name}}</span>
          <span class="ms-pd-item-stats">PDEF {{equippedArmor.system.pdef}} · MDEF {{equippedArmor.system.mdef}}</span>
          {{#if equippedArmor.system.weight}}<span class="ms-pd-item-weight">{{equippedArmor.system.weight}} wt</span>{{/if}}
          <a class="ms-pd-remove" data-action="toggleEquip" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
        {{else}}
        <div class="ms-pd-icon ghost"><i class="fas fa-shirt"></i></div>
        <span class="ms-pd-hint">Drag armor here</span>
        <span class="ms-pd-hint-stats">PDEF · MDEF</span>
        {{/if}}
      </div>

      {{!-- ── Connectors ── --}}
      <div class="ms-pd-conn conn-tl"></div>
      <div class="ms-pd-conn conn-t"></div>
      <div class="ms-pd-conn conn-tr"></div>
      <div class="ms-pd-conn conn-l"></div>
      <div class="ms-pd-conn conn-r"></div>
      <div class="ms-pd-conn conn-bl"></div>
      <div class="ms-pd-conn conn-b"></div>
      <div class="ms-pd-conn conn-br"></div>

      {{!-- ── Main Hand (left) ── --}}
      <div class="ms-pd-slot weapon-card {{#if equippedWeapon}}filled{{else}}empty{{/if}}" data-slot="mainhand">
        <div class="ms-pd-label">Main Hand</div>
        {{#if equippedWeapon}}
        <div class="slot-card-inner" data-item-id="{{equippedWeapon.id}}">
          <div class="ms-pd-icon">
            <img src="{{equippedWeapon.img}}" data-action="postItemToChat" />
          </div>
          <span class="ms-pd-item-name" data-action="editItem">{{equippedWeapon.name}}</span>
          <span class="ms-pd-item-stats">Mt {{equippedWeapon.system.might}} · Crit {{equippedWeapon.system.crit}}</span>
          {{#if equippedWeapon.system.weight}}<span class="ms-pd-item-weight">{{equippedWeapon.system.weight}} wt</span>{{/if}}
          <a class="ms-pd-remove" data-action="toggleEquip" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
        {{else}}
        <div class="ms-pd-icon ghost"><i class="fas fa-sword"></i></div>
        <span class="ms-pd-hint">Drag weapon here</span>
        <span class="ms-pd-hint-stats">Mt · Crit</span>
        {{/if}}
      </div>

      {{!-- ── Central Portrait ── --}}
      <div class="ms-pd-portrait">
        <div class="ms-pd-orbit"></div>
        <div class="ms-pd-diamond">
          <img src="{{actor.img}}" alt="" />
        </div>
      </div>

      {{!-- ── Off Hand (right) ── --}}
      {{#if mainhandIs2H}}
      <div class="ms-pd-slot offhand-card disabled" data-slot="offhand">
        <div class="ms-pd-label">Off Hand</div>
        <div class="ms-pd-icon ghost"><i class="fas fa-fist-raised"></i></div>
        <span class="ms-pd-hint">Two-handing</span>
      </div>
      {{else}}
      <div class="ms-pd-slot offhand-card {{#if equippedOffhand}}filled{{else}}empty{{/if}}" data-slot="offhand">
        <div class="ms-pd-label">Off Hand</div>
        {{#if equippedOffhand}}
        <div class="slot-card-inner" data-item-id="{{equippedOffhand.id}}">
          <div class="ms-pd-icon">
            <img src="{{equippedOffhand.img}}" data-action="postItemToChat" />
          </div>
          <span class="ms-pd-item-name" data-action="editItem">{{equippedOffhand.name}}</span>
          <span class="ms-pd-item-stats">Mt {{equippedOffhand.system.might}} · Crit {{equippedOffhand.system.crit}}</span>
          {{#if equippedOffhand.system.weight}}<span class="ms-pd-item-weight">{{equippedOffhand.system.weight}} wt</span>{{/if}}
          <a class="ms-pd-remove" data-action="unequipOffhand" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
        {{else}}
        <div class="ms-pd-icon ghost"><i class="fas fa-shield-halved"></i></div>
        <span class="ms-pd-hint">Drag off-hand here</span>
        <span class="ms-pd-hint-stats">Shield · Weapon</span>
        {{/if}}
      </div>
      {{/if}}

      {{!-- ── Accessories (bottom) ── --}}
      {{#each accessorySlots}}
      <div class="ms-pd-slot ms-pd-acc-{{@index}} loadout-accessories paperdoll-accessory-slot {{#if this}}filled{{else}}empty{{/if}}" data-slot="accessory" data-slot-index="{{@index}}">
        <div class="ms-pd-label">Accessory</div>
        {{#if this}}
        <div class="slot-card-inner" data-item-id="{{this.id}}">
          <div class="ms-pd-icon">
            <img src="{{this.img}}" data-action="postItemToChat" />
          </div>
          <span class="ms-pd-item-name" data-action="editItem">{{this.name}}</span>
          {{#if this.system.weight}}<span class="ms-pd-item-weight">{{this.system.weight}} wt</span>{{/if}}
          <a class="ms-pd-remove" data-action="toggleEquip" title="Unequip"><i class="fas fa-times"></i></a>
        </div>
        {{else}}
        <div class="ms-pd-icon ghost"><i class="fas fa-ring"></i></div>
        <span class="ms-pd-hint">Accessory slot</span>
        {{/if}}
      </div>
      {{/each}}

    </div>
  </div>

  {{!-- ═══ WEIGHT ═══ --}}
  <div class="ms-section">
    <div class="ms-section-header equip"><div class="sh-gem"></div>Weight</div>
    <div class="ms-weight-bar-wrap">
      <div class="ms-weight-track">
        <div class="ms-weight-fill" style="width: {{#if system.carryingCapacity}}{{math system.totalWeight "*" 100 "/" system.carryingCapacity}}%{{else}}0%{{/if}};"></div>
      </div>
      <div class="ms-weight-border"></div>
    </div>
    <div class="ms-weight-labels">
      <div class="ms-weight-breakdown">
        <span class="ms-wb-item"><span>Wpn</span> {{system.weightBreakdown.weapon}}</span>
        <span class="ms-wb-item"><span>Off</span> {{system.weightBreakdown.offhand}}</span>
        <span class="ms-wb-item"><span>Arm</span> {{system.weightBreakdown.armor}}</span>
        <span class="ms-wb-item"><span>Acc</span> {{system.weightBreakdown.accessory}}</span>
      </div>
      <span class="ms-weight-total {{#if system.overencumbered}}overencumbered{{/if}}">{{system.totalWeight}} / {{system.carryingCapacity}}</span>
    </div>
  </div>

  {{!-- ═══ INVENTORY ═══ --}}
  <div class="ms-section">
    <div class="ms-inv-header">
      <div class="ms-section-header inv" style="margin-bottom:0"><div class="sh-gem"></div>Inventory</div>
      <div class="ms-inv-actions">
        <a class="ms-inv-add" data-action="addItem" data-type="weapon" title="Add Weapon"><i class="fas fa-sword"></i></a>
        <a class="ms-inv-add" data-action="addItem" data-type="armor" title="Add Armor"><i class="fas fa-shield-halved"></i></a>
        <a class="ms-inv-add" data-action="addItem" data-type="accessory" title="Add Accessory"><i class="fas fa-ring"></i></a>
        <a class="ms-inv-add" data-action="addItem" data-type="consumable" title="Add Consumable"><i class="fas fa-flask"></i></a>
      </div>
    </div>

    {{!-- Eiress --}}
    <div class="ms-currency-bar">
      <i class="fas fa-coins ms-currency-icon"></i>
      <span class="ms-currency-label">Eiress</span>
      <div class="ms-currency-controls">
        <button type="button" class="ms-currency-btn" data-action="adjustEiress" data-delta="-1"><i class="fas fa-minus"></i></button>
        <input type="number" name="system.eiress" value="{{system.eiress}}" min="0" data-dtype="Number" class="ms-currency-val" />
        <button type="button" class="ms-currency-btn" data-action="adjustEiress" data-delta="1"><i class="fas fa-plus"></i></button>
      </div>
    </div>

    {{!-- Item Grid --}}
    {{#if inventory.length}}
    <div class="inventory-grid ms-inv-grid">
      {{#each inventory}}
      <div class="ms-inv-card item draggable" data-item-id="{{this.id}}" data-item-type="{{this.type}}" draggable="true">
        <img src="{{this.img}}" class="ms-inv-card-img" data-action="postItemToChat" />
        <span class="ms-inv-card-name">{{this.name}}</span>
        {{#if (eq this.type "consumable")}}<span class="ms-inv-card-qty">x{{this.system.quantity}}</span>{{/if}}
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="ms-empty-state">
      <i class="fas fa-box-open"></i>
      <span>No items in inventory.</span>
    </div>
    {{/if}}
  </div>

</section>
