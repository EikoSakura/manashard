    <div class="ms-section-header skl"><div class="sh-gem"></div>Skills
      {{#if allActiveSkills.length}}<span class="ms-count-badge">{{allActiveSkills.length}}</span>{{/if}}
    </div>
    {{#if allActiveSkills.length}}
    <div class="ms-skill-grid">
      {{#each allActiveSkills}}
      <div class="ms-skill-card act skill-grid-card {{this.skillType}} {{#if this._isTaught}}taught{{/if}}" data-item-id="{{this.id}}">
        <div class="ms-skill-icon act-i">
