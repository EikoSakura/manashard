{{!-- Crystal Combat Tab --}}
<section class="tab-content {{tab.cssClass}}" data-tab="stats">

  {{#if isCharacter}}
  {{!-- ════════════════════════════════════════════════ --}}
  {{!-- Adventurer: Combat Profile                      --}}
  {{!-- ════════════════════════════════════════════════ --}}

  {{!-- Offense --}}
  <div class="ms-section">
    <div class="ms-section-header off"><div class="sh-gem"></div>Offense</div>
    <div class="ms-offense-grid">
      <div class="ms-hero-stat primary" data-stat="damage">
        <div class="hero-val {{derivedModifiers.damage.modClass}}">{{system.damage}}</div>
        <div class="hero-label">DMG</div>
        {{#if derivedSources.damage}}<div class="hero-source">{{derivedSources.damage}}</div>{{/if}}
      </div>
      <div class="ms-hero-stat secondary" data-stat="accuracy">
        <div class="hero-val {{derivedModifiers.accuracy.modClass}}">{{system.accuracy}}</div>
        <div class="hero-label">ACC</div>
      </div>
      <div class="ms-hero-stat secondary" data-stat="critical">
        <div class="hero-val {{derivedModifiers.critical.modClass}}">{{system.critical}}</div>
        <div class="hero-label">CRIT</div>
      </div>
    </div>
  </div>

  {{!-- Defense --}}
  <div class="ms-section">
    <div class="ms-section-header def"><div class="sh-gem"></div>Defense</div>
    <div class="ms-defense-grid">
      <div class="ms-def-cell" data-stat="peva">
        <div class="def-val {{derivedModifiers.peva.modClass}}">{{system.peva}}</div>
        <div class="def-label">P.EVA</div>
      </div>
      <div class="ms-def-cell" data-stat="meva">
        <div class="def-val {{derivedModifiers.meva.modClass}}">{{system.meva}}</div>
        <div class="def-label">M.EVA</div>
      </div>
      <div class="ms-def-cell" data-stat="critEvo">
        <div class="def-val {{derivedModifiers.critEvo.modClass}}">{{system.critEvo}}</div>
        <div class="def-label">C.EVO</div>
      </div>
      <div class="ms-def-cell" data-stat="pdef">
        <div class="def-val {{derivedModifiers.pdef.modClass}}">{{system.pdef}}</div>
        <div class="def-label">P.DEF</div>
      </div>
      <div class="ms-def-cell" data-stat="mdef">
        <div class="def-val {{derivedModifiers.mdef.modClass}}">{{system.mdef}}</div>
        <div class="def-label">M.DEF</div>
      </div>
      <div class="ms-def-cell" data-stat="blockChance">
        <div class="def-val {{derivedModifiers.blockChance.modClass}}">{{system.blockChance}}%</div>
        <div class="def-label">BLK</div>
      </div>
    </div>
  </div>

  {{!-- Tactical --}}
  <div class="ms-section">
    <div class="ms-section-header tac"><div class="sh-gem"></div>Tactical</div>
    <div class="ms-tactical-row">
      <div class="ms-tac-chip" data-stat="mov">
        <span class="tac-label">MOV</span>
        <span class="tac-val {{derivedModifiers.mov.modClass}}">{{system.mov}}</span>
      </div>
      <div class="ms-tac-chip" data-stat="vision">
        <span class="tac-label">VIS</span>
        <span class="tac-val {{derivedModifiers.vision.modClass}}">{{system.vision}}</span>
      </div>
      <div class="ms-tac-chip" data-stat="mpRegen">
        <span class="tac-label">MP RGN</span>
        <span class="tac-val {{derivedModifiers.mpRegen.modClass}}">{{system.mpRegen}}</span>
      </div>
      <div class="ms-tac-chip" data-stat="carry">
        <span class="tac-label">CARRY</span>
        <span class="tac-val {{#if system.overencumbered}}overencumbered{{/if}}">{{system.totalWeight}}/{{system.carryingCapacity}}</span>
      </div>
      <div class="ms-tac-chip tag-group">
        <span class="tac-label">MOVE</span>
        <span class="tac-val">{{{movementModeTags}}}</span>
      </div>
      <div class="ms-tac-chip tag-group">
        <span class="tac-label">TYPE</span>
        <span class="tac-val">{{{creatureTypeTags}}}</span>
      </div>
    </div>
  </div>

  {{!-- Status Effects --}}
  <div class="ms-section">
    <div class="ms-section-header sts"><div class="sh-gem"></div>Status Effects</div>
    <div class="ms-status-row">
      {{#each statusEffectEntries}}
      <span class="ms-status-tag {{#if this.active}}active{{/if}}"
            data-action="toggleStatus" data-status="{{this.key}}">
        {{this.label}}
        {{#if this.duration}}<span class="ms-status-duration">{{this.duration}}</span>{{/if}}
      </span>
      {{/each}}
    </div>
  </div>

  {{!-- Weapons --}}
  <div class="ms-section">
    <div class="ms-section-header wpn"><div class="sh-gem"></div>Weapons</div>
    <div class="ms-skill-grid">
      {{#if equippedWeapon}}
      <div class="ms-skill-card wpn inventory-grid-card" data-item-id="{{equippedWeapon.id}}">
        <div class="ms-skill-icon wpn-i">
          <img src="{{equippedWeapon.img}}" alt="{{equippedWeapon.name}}" data-action="editItem" />
        </div>
        <div class="ms-skill-info">
          <span class="ms-skill-name">{{equippedWeapon.name}}</span>
          <div class="ms-skill-meta">
            <span class="ms-meta-tag">Mt {{equippedWeapon.system.might}}</span>
            <span class="ms-meta-tag">Crit {{equippedWeapon.system.crit}}</span>
          </div>
        </div>
        <a class="ms-skill-action" data-action="rollAttack" title="Attack"><i class="fas fa-dice-d20"></i></a>
      </div>
      {{else}}
      <div class="ms-skill-card wpn empty">
        <div class="ms-skill-icon wpn-i">
          <i class="fas fa-sword"></i>
        </div>
        <span class="ms-skill-name muted">Unarmed</span>
      </div>
      {{/if}}
      {{#each naturalWeapons}}
      <div class="ms-skill-card wpn inventory-grid-card" data-item-id="{{this.id}}">
        <div class="ms-skill-icon wpn-i">
          <img src="{{this.img}}" alt="{{this.name}}" data-action="editItem" />
        </div>
        <div class="ms-skill-info">
          <span class="ms-skill-name">{{this.name}}</span>
          <div class="ms-skill-meta">
            <span class="ms-meta-tag">Mt {{this.system.might}}</span>
            <span class="ms-meta-tag">Crit {{this.system.crit}}</span>
          </div>
        </div>
        <a class="ms-skill-action" data-action="rollNaturalAttack" title="Attack"><i class="fas fa-dice-d20"></i></a>
      </div>
      {{/each}}
    </div>
  </div>

  {{!-- Combat Skills --}}
  <div class="ms-section">
    <div class="ms-section-header skl"><div class="sh-gem"></div>Skills
      {{#if combatSkills.length}}<span class="ms-count-badge">{{combatSkills.length}}</span>{{/if}}
    </div>
    {{#if combatSkills.length}}
    <div class="ms-skill-grid">
      {{#each combatSkills}}
      <div class="ms-skill-card act skill-grid-card {{this.system.skillType}} {{#if this._isTaught}}taught{{/if}}" data-item-id="{{this.id}}">
        <div class="ms-skill-icon act-i">
          <img src="{{this.img}}" alt="{{this.name}}" data-action="postItemToChat" title="Post to chat" />
        </div>
        <div class="ms-skill-info">
          <span class="ms-skill-name">{{this.name}}</span>
          <div class="ms-skill-meta">
            {{#if this.system.mpCost}}<span class="ms-meta-tag mp">MP {{this.system.mpCost}}</span>{{/if}}
            {{#if this.system.element}}<span class="ms-meta-tag element-pip element-{{this.system.element}}">{{this.system.element}}</span>{{/if}}
          </div>
        </div>
        {{#if (eq this.system.skillType "magic")}}
        <a class="ms-skill-action cast" data-action="useSkill" title="Cast"><i class="fas fa-hat-wizard"></i></a>
        {{else}}
        <a class="ms-skill-action activate" data-action="useSkill" title="Activate"><i class="fas fa-dice-d20"></i></a>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="ms-empty-state">
      <i class="fas fa-magic-wand-sparkles"></i>
      <span>No Skills Available</span>
    </div>
    {{/if}}
  </div>

  {{!-- Passives --}}
  {{#if passiveAbilities.length}}
  <div class="ms-section">
    <div class="ms-section-header pas"><div class="sh-gem"></div>Passives
      <span class="ms-count-badge">{{passiveAbilities.length}}</span>
    </div>
    <div class="ms-passive-grid">
      {{#each passiveAbilities}}
      <div class="ms-skill-card pas skill-grid-card" data-item-id="{{this.id}}">
        <div class="ms-skill-icon pas-i">
          <img src="{{this.img}}" alt="{{this.name}}" data-action="postItemToChat" title="Post to chat" />
        </div>
        <span class="ms-skill-name">{{this.name}}</span>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- Consumables --}}
  {{#if consumables.length}}
  <div class="ms-section">
    <div class="ms-section-header itm"><div class="sh-gem"></div>Items</div>
    <div class="ms-skill-grid">
      {{#each consumables}}
      <div class="ms-skill-card itm inventory-grid-card" data-item-id="{{this.id}}">
        <div class="ms-skill-icon itm-i">
          <img src="{{this.img}}" alt="{{this.name}}" />
        </div>
        <div class="ms-skill-info">
          <span class="ms-skill-name">{{this.name}}</span>
          <span class="ms-item-qty">x{{this.system.quantity}}</span>
        </div>
        <a class="ms-skill-action consume" data-action="useConsumable" title="Use"><i class="fas fa-flask"></i></a>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{else}}

  {{#if isThreat}}
  {{!-- ════════════════════════════════════════════════ --}}
  {{!-- Threat: Combat Profile                          --}}
  {{!-- ════════════════════════════════════════════════ --}}

  {{!-- Offense --}}
