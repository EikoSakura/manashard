{{!-- Crystal Sidebar --}}
<aside class="ms-sidebar">
  <div class="ms-sidebar-bg"></div>
  <div class="ms-sidebar-glow"></div>
  <div class="ms-sidebar-inner">

    {{!-- Portrait Diamond --}}
    <div class="ms-portrait-wrap">
      <div class="ms-orbit-ring">
        <div class="ms-orbit-gem og-top"></div>
        <div class="ms-orbit-gem og-bottom"></div>
        <div class="ms-orbit-gem og-left"></div>
        <div class="ms-orbit-gem og-right"></div>
      </div>
      <div class="ms-portrait-diamond" data-action="editImage">
        <div class="portrait-img-wrap">
          <img src="{{actor.img}}" alt="{{actor.name}}" />
        </div>
      </div>
      <div class="ms-corner-cross cc-top"></div>
      <div class="ms-corner-cross cc-bottom"></div>
    </div>

    {{!-- Character Name (editable) --}}
    <div class="ms-char-name">
      <input type="text" name="name" value="{{actor.name}}" placeholder="Name" />
    </div>

    {{!-- Level badge --}}
    {{#if isThreat}}
    <div class="hu-level-rank-row">
      <div class="hu-lr-cell">
        <span class="hu-lr-label">LEVEL</span>
        <input type="number" name="system.level" value="{{system.level}}" min="1" class="hu-lr-value" />
      </div>
      <div class="hu-lr-cell">
        <span class="hu-lr-label">RANK</span>
        <select name="system.rank" class="hu-lr-value hu-rank-inline-select">
          {{#each rankOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    <div class="hu-threat-pips sidebar-threat-pips">
      <span class="hu-threat-label">THREAT</span>
      {{#each threatPips}}
      <span class="hu-threat-pip {{#if this}}filled{{/if}}"></span>
      {{/each}}
    </div>
    {{else}}
    <div class="ms-class-tag">
      Level {{system.level}}
    </div>
    {{/if}}

    {{!-- Species & Job sub-badges --}}
    <div class="ms-sub-tag-row">
      {{#if equippedSpecies}}
      <div class="ms-sub-tag species" data-item-id="{{equippedSpecies.id}}" data-action="editItem">
        <img src="{{equippedSpecies.img}}" class="ms-sub-tag-icon" />
        <span>{{equippedSpecies.name}}</span>
      </div>
      {{/if}}
      {{#if equippedJob}}
      <div class="ms-sub-tag job" data-item-id="{{equippedJob.id}}" data-action="editItem">
        <img src="{{equippedJob.img}}" class="ms-sub-tag-icon" />
        <span>{{equippedJob.name}}</span>
      </div>
      {{/if}}
    </div>

    <div class="ms-gem-divider">
      <span class="gem-sm"></span>
      <span class="gem-lg"></span>
      <span class="gem-sm"></span>
    </div>

    {{!-- HP Bar --}}
    <div class="ms-vital-bar">
      <div class="ms-vital-header">
        <span class="vital-label hp">HP</span>
        <span class="vital-nums">
          <input type="number" name="system.stats.hp.value" value="{{system.stats.hp.value}}" min="0" />
          <span class="vital-sep">/</span>
          <input type="number" name="system.stats.hp.max" value="{{system.stats.hp.max}}" min="0" class="vital-max" />
        </span>
      </div>
      <div style="position: relative;">
        <div class="ms-vital-track">
          <div class="ms-vital-fill hp" style="width: {{hpPercent}}%;"></div>
        </div>
        <div class="ms-vital-border"></div>
      </div>
    </div>

    {{!-- MP Bar --}}
    <div class="ms-vital-bar">
      <div class="ms-vital-header">
        <span class="vital-label mp">MP</span>
        <span class="vital-nums">
          <input type="number" name="system.stats.mp.value" value="{{system.stats.mp.value}}" min="0" />
          <span class="vital-sep">/</span>
          <input type="number" name="system.stats.mp.max" value="{{system.stats.mp.max}}" min="0" class="vital-max" />
        </span>
      </div>
      <div style="position: relative;">
        <div class="ms-vital-track">
          <div class="ms-vital-fill mp" style="width: {{mpPercent}}%;"></div>
        </div>
        <div class="ms-vital-border"></div>
      </div>
    </div>

    <div class="ms-gem-divider">
      <span class="gem-sm"></span>
      <span class="gem-lg"></span>
      <span class="gem-sm"></span>
    </div>

    {{!-- EXP & Level Up --}}
    {{#if isCharacter}}
    <div class="ms-exp-row">
      <div class="ms-exp-hex">
        <div class="exp-val">
          <input type="number" name="system.exp" value="{{system.exp}}" min="0" class="ms-exp-input" />
        </div>
        <div class="exp-label">EXP /100</div>
      </div>
      {{#if canLevelUp}}
      <button type="button" class="ms-levelup-btn" data-action="levelUp" title="Level Up!">
        <i class="fas fa-arrow-up"></i>
      </button>
      {{/if}}
    </div>

    <div class="ms-gem-divider">
      <span class="gem-sm"></span>
      <span class="gem-lg"></span>
      <span class="gem-sm"></span>
    </div>
    {{/if}}

    {{!-- Core Stats --}}
    <div class="ms-stats-header">
      <div class="bar-accent"></div>
      Core stats
    </div>
    <div class="ms-stat-grid">
      {{#each statEntries}}
      {{#unless this.isResource}}
      <div class="ms-stat {{#if (eq this.key 'str')}}phys{{/if}}{{#if (eq this.key 'agi')}}phys{{/if}}{{#if (eq this.key 'mag')}}mag{{/if}}{{#if (eq this.key 'end')}}mag{{/if}}{{#if (eq this.key 'spi')}}mag{{/if}}{{#if (eq this.key 'luk')}}util{{/if}}{{#if (eq this.key 'int')}}soc{{/if}}{{#if (eq this.key 'chm')}}soc{{/if}}"
           data-action="rollStat" data-stat="{{this.key}}">
        <span class="stat-label">{{upper this.abbr}}</span>
        <span class="stat-value {{this.modClass}}">{{this.value}}</span>
      </div>
      {{/unless}}
      {{/each}}
    </div>

    <div class="ms-gem-divider">
      <span class="gem-sm"></span>
      <span class="gem-lg"></span>
      <span class="gem-sm"></span>
    </div>

    {{!-- Elemental Profile --}}
    <div class="ms-section sidebar-section">
      <div class="ms-section-header" style="color:#e84393;"><div class="sh-gem" style="background:#e84393;"></div>Elemental profile</div>
      <div class="ms-element-grid sidebar-grid">
        {{#each elementalEntries}}
        <div class="ms-el-cell el-{{this.key}} tier-{{this.tier}}"
             data-action="cycleElementTier" data-element="{{this.key}}"
             title="{{this.label}}: {{this.tierLabel}}">
          <div class="ms-el-dot"></div>
          <div class="ms-el-name">{{this.label}}</div>
          <div class="ms-el-tier">{{this.tierLabel}}</div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Status Resistances --}}
    <div class="ms-section sidebar-section">
      <div class="ms-section-header sts"><div class="sh-gem"></div>Status resistances</div>
      <div class="ms-sr-grid sidebar-grid">
        {{#each statusResistanceEntries}}
        <div class="ms-sr-cell tier-{{this.tier}}"
             data-action="cycleStatusTier" data-status="{{this.key}}"
             title="{{this.label}}: {{this.tierLabel}}">
          <div class="ms-sr-dot"></div>
          <div class="ms-sr-name">{{this.label}}</div>
          <div class="ms-sr-tier">{{this.tierLabel}}</div>
        </div>
        {{/each}}
      </div>
    </div>

  </div>
</aside>
