<section class="tab-content {{tab.cssClass}}" data-tab="description">
<div class="item-description-display">

  {{!-- ═══ WEAPON — Crystal Stats + Tooltip ═══ --}}
  {{#if (eq itemType "weapon")}}
  <div class="ms-item-stats cols-3">
    <div class="ms-item-stat">
      <div class="is-val">{{system.might}}</div>
      <div class="is-label">Might</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val">{{system.crit}}</div>
      <div class="is-label">Crit</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val">{{system.weight}}</div>
      <div class="is-label">Weight</div>
    </div>
  </div>

  <div class="ms-item-props">
    <div class="ms-item-prop">
      <span class="prop-label">Hands</span>
      <span class="prop-val">{{handednessLabel}}</span>
    </div>
    <div class="ms-item-prop">
      <span class="prop-label">Range</span>
      <span class="prop-val">{{system.rangeDisplay}}</span>
    </div>
    <div class="ms-item-prop">
      <span class="prop-label">Dmg</span>
      <span class="prop-val">{{damageTypeLabel}}</span>
    </div>
    {{#if system.element}}
    <div class="ms-item-prop">
      <span class="prop-label">Element</span>
      <span class="prop-val">{{elementLabel}}</span>
    </div>
    {{/if}}
    {{#if system.rank}}
    <div class="ms-item-prop">
      <span class="prop-label">Rank</span>
      <span class="prop-val">{{upper system.rank}}</span>
    </div>
    {{/if}}
    {{#if (eq system.category "shields")}}
    <div class="ms-item-prop">
      <span class="prop-label">Block</span>
      <span class="prop-val">{{system.block}}</span>
    </div>
    {{/if}}
  </div>

  {{!-- Properties from rules --}}
  {{#if (or weaponStatBonuses.length categoryIdentity weaponTagDetails.length system.special weaponEffects.length)}}
  <div class="ms-item-rules">
    {{#each weaponStatBonuses}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas fa-arrow-up"></i> {{this.label}}</span>
      <span>{{this.display}}</span>
    </div>
    {{/each}}
    {{#if categoryIdentity}}
    <div class="ms-item-rule ms-item-rule--tip">
      <span class="rule-type"><i class="fas fa-shield-halved"></i> Trait</span>
      <span class="rule-label">{{categoryIdentity.label}}</span>
      <span class="rule-desc">{{categoryIdentity.description}}</span>
    </div>
    {{/if}}
    {{#each weaponTagDetails}}
    <div class="ms-item-rule ms-item-rule--tip">
      <span class="rule-type"><i class="fas fa-tag"></i> Tag</span>
      <span class="rule-label">{{this.label}}</span>
      <span class="rule-desc">{{this.description}}</span>
    </div>
    {{/each}}
    {{#if system.special}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas fa-diamond"></i> Special</span>
      <span>{{system.special}}</span>
    </div>
    {{/if}}
    {{#each weaponEffects}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas {{this.icon}}"></i> Effect</span>
      <span>{{this.summary}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <div class="ms-item-props">
    <div class="ms-item-prop">
      <span class="prop-label">Price</span>
      <span class="prop-val">{{system.price}}</span>
    </div>
  </div>
  {{/if}}

  {{!-- ═══ ARMOR — Crystal Stats ═══ --}}
  {{#if (eq itemType "armor")}}
  <div class="ms-item-stats cols-3">
    <div class="ms-item-stat">
      <div class="is-val">{{system.pdef}}</div>
      <div class="is-label">P.DEF</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val">{{system.mdef}}</div>
      <div class="is-label">M.DEF</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val">{{system.weight}}</div>
      <div class="is-label">Weight</div>
    </div>
  </div>

  <div class="ms-item-props">
    <div class="ms-item-prop">
      <span class="prop-label">Category</span>
      <span class="prop-val">{{categoryLabel}}</span>
    </div>
    {{#if system.rank}}
    <div class="ms-item-prop">
      <span class="prop-label">Rank</span>
      <span class="prop-val">{{upper system.rank}}</span>
    </div>
    {{/if}}
    <div class="ms-item-prop">
      <span class="prop-label">Price</span>
      <span class="prop-val">{{system.price}}</span>
    </div>
  </div>

  {{#if armorStatBonuses.length}}
  <div class="ms-item-rules">
    {{#each armorStatBonuses}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas fa-arrow-up"></i> {{this.label}}</span>
      <span>{{this.display}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if (or system.special armorEffects.length)}}
  <div class="ms-item-rules">
    {{#if system.special}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas fa-diamond"></i> Special</span>
      <span>{{system.special}}</span>
    </div>
    {{/if}}
    {{#each armorEffects}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas {{this.icon}}"></i> Effect</span>
      <span>{{this.summary}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- ═══ ACCESSORY — Crystal Stats ═══ --}}
  {{#if (eq itemType "accessory")}}
  <div class="ms-item-stats cols-2">
    <div class="ms-item-stat">
      <div class="is-val">{{system.weight}}</div>
      <div class="is-label">Weight</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val" style="font-size:13px;color:#55efc4;">{{#if accessoryStatBonuses.length}}Active{{else}}—{{/if}}</div>
      <div class="is-label">Bonus</div>
    </div>
  </div>

  <div class="ms-item-props">
    {{#if system.rank}}
    <div class="ms-item-prop">
      <span class="prop-label">Rank</span>
      <span class="prop-val">{{upper system.rank}}</span>
    </div>
    {{/if}}
    <div class="ms-item-prop">
      <span class="prop-label">Price</span>
      <span class="prop-val">{{system.price}}</span>
    </div>
  </div>

  {{#if accessoryStatBonuses.length}}
  <div class="ms-item-rules">
    {{#each accessoryStatBonuses}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas fa-arrow-up"></i> {{this.label}}</span>
      <span>{{this.display}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if accessoryEffects.length}}
  <div class="ms-item-rules">
    {{#each accessoryEffects}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas {{this.icon}}"></i> Effect</span>
      <span>{{this.summary}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- ═══ SKILL MANACITE — Crystal Stats ═══ --}}
  {{#if (and (eq itemType "manacite") (eq system.manaciteType "skill"))}}
  {{#if (or (eq system.skillType "magic") (eq system.skillType "art"))}}
  <div class="ms-item-stats cols-3">
    <div class="ms-item-stat">
      <div class="is-val" style="color:#5599ee;">{{effectiveMpCost}}</div>
      <div class="is-label">MP Cost</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val">{{#if isWeaponMode}}+{{/if}}{{effectiveBaseRate}}</div>
      <div class="is-label">{{#if isWeaponMode}}Bonus Dmg{{else}}Damage{{/if}}</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val">{{#if effectiveSkillHit}}{{effectiveSkillHit}}{{else}}—{{/if}}</div>
      <div class="is-label">Hit Rate</div>
    </div>
  </div>

  <div class="ms-item-props">
    <div class="ms-item-prop">
      <span class="prop-label">Type</span>
      <span class="prop-val">{{skillTypeLabel}}</span>
    </div>
    <div class="ms-item-prop">
      <span class="prop-label">{{#if (or (eq system.rangeType "melee") (eq system.rangeType "weapon"))}}Reach{{else}}Range{{/if}}</span>
      <span class="prop-val">{{#if system.rangeDisplay}}{{system.rangeDisplay}}{{else}}—{{/if}}</span>
    </div>
    <div class="ms-item-prop">
      <span class="prop-label">Mode</span>
      <span class="prop-val">{{manaDmgModeLabel}}</span>
    </div>
    <div class="ms-item-prop">
      <span class="prop-label">Target</span>
      <span class="prop-val">{{manaTargetLabel}}</span>
    </div>
    {{#if system.element}}
    <div class="ms-item-prop">
      <span class="prop-label">Element</span>
      <span class="prop-val">{{elementLabel}}</span>
    </div>
    {{/if}}
  </div>

  {{#if manaAoeLabel}}
  <div class="ms-item-props">
    <div class="ms-item-prop">
      <span class="prop-label">AOE</span>
      <span class="prop-val">{{manaAoeLabel}}</span>
    </div>
  </div>
  {{/if}}
  {{/if}}

  {{!-- Passive banner --}}
  {{#if (eq system.skillType "passive")}}
  <div class="ms-item-props">
    <div class="ms-item-prop">
      <span class="prop-label"><i class="fas fa-shield-halved"></i> Passive</span>
      <span class="prop-val">{{passiveModeLabel}}</span>
    </div>
  </div>
  {{/if}}

  {{!-- Skill effects from rules --}}
  {{#if manaEffects.length}}
  <div class="ms-item-rules">
    {{#each manaEffects}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas {{this.icon}}"></i></span>
      <span>{{this.label}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if system.absorbed}}
  <div class="ms-item-toggle">
    <i class="fas fa-check-circle" style="color:#55efc4;"></i>
    <span class="toggle-label">Absorbed</span>
  </div>
  {{/if}}
  {{/if}}

  {{!-- ═══ JOB MANACITE — Crystal Growth Grid ═══ --}}
  {{#if (and (eq itemType "manacite") (eq system.manaciteType "job"))}}
  <div class="ms-item-sec" style="color:#2ecc71;">
    <div class="sec-gem" style="background:#2ecc71;"></div>
    Growth Rate Bonuses
  </div>
  <div class="ms-growth-grid">
    {{#each growthEntries}}
    <div class="ms-growth-cell gc-{{this.category}}">
      <div class="gc-label">{{this.label}}</div>
      <div class="gc-val">{{this.value}}%</div>
    </div>
    {{/each}}
  </div>

  {{#if jobStatBonuses.length}}
  <div class="ms-item-sec" style="color:#a78bfa;">
    <div class="sec-gem" style="background:#a78bfa;"></div>
    Bonus Stats
  </div>
  <div class="ms-item-rules">
    {{#each jobStatBonuses}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas fa-arrow-up"></i> {{this.label}}</span>
      <span>{{this.display}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if jobEffects.length}}
  <div class="ms-item-sec" style="color:#a78bfa;">
    <div class="sec-gem" style="background:#a78bfa;"></div>
    Effects
  </div>
  <div class="ms-item-rules">
    {{#each jobEffects}}
    <div class="ms-item-rule">
      <span class="rule-type"><i class="fas {{this.icon}}"></i></span>
      <span>{{this.summary}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if grantedItems.length}}
  <div class="ms-item-sec" style="color:#4eb9d4;">
    <div class="sec-gem" style="background:#4eb9d4;"></div>
    Granted Skills
  </div>
  <div class="ms-granted-skills">
    {{#each grantedItems}}
    <div class="ms-granted-skill" {{#if this.description}}data-tooltip="{{this.description}}"{{/if}} data-action="viewGrantedItem" data-uuid="{{this.uuid}}">
      <img src="{{this.img}}" alt="{{this.name}}" />
      {{this.name}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if prerequisites.length}}
  <div class="ms-item-sec" style="color:#d4a842;">
    <div class="sec-gem" style="background:#d4a842;"></div>
    Prerequisites
  </div>
  <div class="ms-granted-skills">
    {{#each prerequisites}}
    <div class="ms-granted-skill ms-prereq-skill">
      {{#if this.img}}<img src="{{this.img}}" alt="{{this.name}}" />{{/if}}
      <span class="prereq-badge-inline">{{this.type}}</span>
      {{this.name}}{{#if (eq this.type "skill")}} <span class="prereq-lv-inline">Lv{{this.level}}</span>{{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- ═══ CONSUMABLE — Crystal Stats ═══ --}}
  {{#if (eq itemType "consumable")}}
  <div class="ms-item-stats cols-2">
    <div class="ms-item-stat">
      <div class="is-val">{{system.quantity}}</div>
      <div class="is-label">Quantity</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val" style="color:var(--manashard-accent);">{{upper targetTypeLabel}}</div>
      <div class="is-label">Target</div>
    </div>
  </div>

  {{!-- Effects --}}
  {{#if consumableEffects.length}}
  <div class="ms-item-rules">
    {{#each consumableEffects}}
    <div class="ms-item-rule">
      <span class="rule-type" style="color:{{this.color}};background:{{this.bgColor}};"><i class="fas {{this.icon}}"></i></span>
      <span style="color:{{this.color}};">{{this.value}} {{this.label}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if system.effect}}
  <div class="ms-item-props">
    <div class="ms-item-prop">
      <span class="prop-label">Effect</span>
      <span class="prop-val">{{system.effect}}</span>
    </div>
  </div>
  {{/if}}

  <div class="ms-item-props">
    <div class="ms-item-prop">
      <span class="prop-label">Category</span>
      <span class="prop-val">{{categoryLabel}}</span>
    </div>
    <div class="ms-item-prop">
      <span class="prop-label">Price</span>
      <span class="prop-val">{{system.price}}</span>
    </div>
    <div class="ms-item-prop">
      <span class="prop-label">Max</span>
      <span class="prop-val">{{system.maxStack}}</span>
    </div>
  </div>

  {{!-- Use Button --}}
  {{#if item.isOwner}}
  <div style="padding: 6px 0;">
    <button type="button" class="con-tt-use-btn" data-action="useConsumable" {{#unless system.quantity}}disabled{{/unless}}>
      <i class="fas fa-flask"></i> USE
    </button>
  </div>
  {{/if}}
  {{/if}}

  {{!-- ═══ MATERIAL — Crystal Stats ═══ --}}
  {{#if (eq itemType "material")}}
  <div class="ms-item-stats cols-3">
    <div class="ms-item-stat">
      <div class="is-val">{{system.quantity}}</div>
      <div class="is-label">Quantity</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val" style="color:#e8d48b;">{{system.price}}</div>
      <div class="is-label">Price Each</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val" style="color:#55efc4;">{{totalValue}}</div>
      <div class="is-label">Total</div>
    </div>
  </div>

  {{#if materialSources.length}}
  <div class="ms-item-sec" style="color:#5a7a94;">
    <div class="sec-gem" style="background:#5a7a94;"></div>
    Obtained From
  </div>
  <div class="ms-item-props">
    {{#each materialSources}}
    <div class="ms-item-prop">
      <span class="prop-val">{{this}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- ═══ SPECIES — Crystal Description ═══ --}}
  {{#if (eq itemType "species")}}
  <div class="ms-item-stats cols-2">
    <div class="ms-item-stat">
      <div class="is-val">{{system.size}}</div>
      <div class="is-label">Size</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val" style="font-size:13px;color:#a78bfa;">{{rules.length}}</div>
      <div class="is-label">Traits</div>
    </div>
  </div>
  {{/if}}

  {{!-- ═══ GENERIC ITEM — Crystal Stats ═══ --}}
  {{#if (eq itemType "item")}}
  <div class="ms-item-stats cols-3">
    <div class="ms-item-stat">
      <div class="is-val">{{system.quantity}}</div>
      <div class="is-label">Quantity</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val" style="color:#e8d48b;">{{system.price}}</div>
      <div class="is-label">Price</div>
    </div>
    <div class="ms-item-stat">
      <div class="is-val">{{system.weight}}</div>
      <div class="is-label">Weight</div>
    </div>
  </div>
  {{/if}}

  {{!-- ═══ DESCRIPTION (all types) ═══ --}}
  {{#if enrichedDescription}}
  <div class="ms-item-divider"></div>
  <div class="ms-item-desc-area">
    <div class="ms-item-desc-header"><div class="dh-bar"></div>Description</div>
    <div class="ms-item-desc-box">{{{enrichedDescription}}}</div>
  </div>
  {{/if}}

</div>
</section>
