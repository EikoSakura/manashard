{{else}}
{{!-- ═══ DEFAULT ITEM HEADER ═══ --}}
<header class="sheet-header">
  <img class="profile-img" src="{{item.img}}" data-action="editImage"
       title="{{item.name}}" width="64" height="64" />
  <div class="header-fields">
    <h1 class="item-name">
      <input name="name" type="text" value="{{item.name}}" placeholder="Item Name" />
    </h1>
    <span class="item-type-label">{{itemTypeLabel}}</span>
  </div>
</header>
{{/if}}
