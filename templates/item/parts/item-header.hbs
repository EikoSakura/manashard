{{#if (and (eq itemType "manacite") (eq system.manaciteType "job"))}}
{{!-- ═══ JOB MANACITE HEADER — Compact ═══ --}}
<header class="sheet-header job-manacite-header">
  <div class="header-portrait-col job-portrait-compact">
    <div class="portrait-outer">
      <div class="portrait-frame">
        <div class="portrait-diamond">
          <img class="profile-img" src="{{item.img}}" data-action="editImage"
               title="{{item.name}}" />
        </div>
      </div>
    </div>
    <div class="portrait-level-badge">
      <span class="level-label">JOB</span>
    </div>
  </div>

  <div class="header-fields">
    <div class="name-banner">
      <input name="name" type="text" value="{{item.name}}" placeholder="Job Manacite Name" />
    </div>
  </div>
</header>

{{else if (and (eq itemType "manacite") (eq system.manaciteType "skill"))}}
{{!-- ═══ SKILL MANACITE HEADER — Diamond Icon + Badges ═══ --}}
<header class="sheet-header mana-skill-header">
  <div class="mana-skill-header-gradient"></div>
  <div class="mana-skill-header-content">
    <div class="mana-skill-header-icon">
      <img class="profile-img" src="{{item.img}}" data-action="editImage"
           title="{{item.name}}" />
    </div>
    <div class="mana-skill-header-info">
      <div class="name-banner">
        <input name="name" type="text" value="{{item.name}}" placeholder="Skill Manacite Name" />
      </div>
      <div class="mana-skill-header-tags">
        <span class="mana-type-tag">MANACITE</span>
        <span class="mana-badge mana-badge-{{system.skillType}}">{{upper skillTypeLabel}}</span>
        {{#if system.element}}
        <span class="mana-badge mana-badge-element element-badge-{{system.element}}">{{upper elementLabel}}</span>
        {{/if}}
      </div>
    </div>
  </div>
</header>

{{else if (eq itemType "species")}}
{{!-- ═══ SPECIES HEADER — Compact Diamond ═══ --}}
<header class="sheet-header species-sheet-header">
  <div class="header-portrait-col job-portrait-compact">
    <div class="portrait-outer">
      <div class="portrait-frame">
        <div class="portrait-diamond">
          <img class="profile-img" src="{{item.img}}" data-action="editImage"
               title="{{item.name}}" />
        </div>
      </div>
    </div>
    <div class="portrait-level-badge species-glow">
      <span class="level-label">SPECIES</span>
    </div>
  </div>

  <div class="header-fields">
    <div class="name-banner">
      <input name="name" type="text" value="{{item.name}}" placeholder="Species Name" />
    </div>
    <div class="header-info-panel species-header-info">
      <div class="detail-row">
        <div class="detail-cell">
          <span class="detail-label">Size</span>
          <span class="stat-display">{{system.size}}</span>
        </div>
      </div>
    </div>
  </div>
</header>

