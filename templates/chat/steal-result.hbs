<div class="manashard attack-chat-card steal-card">
  {{!-- ═══ HEADER BAR ═══ --}}
  <div class="acc-header">
    <div class="acc-portrait-frame">
      <div class="acc-portrait-diamond">
        <img src="{{actorImg}}" class="acc-portrait" />
      </div>
    </div>
    <div class="acc-header-text">
      <span class="acc-actor-name">{{actorName}}</span>
      <span class="acc-action">uses <strong>{{skillName}}</strong></span>
    </div>
    <span class="acc-target-badge acc-target-steal"><i class="fas fa-hand-sparkles"></i></span>
  </div>

  {{!-- ═══ TARGET LINE ═══ --}}
  {{#if targetName}}
  <div class="acc-target-line">
    <i class="fas fa-arrow-right acc-target-arrow"></i>
    <span class="acc-target-name">{{targetName}}</span>
  </div>
  {{/if}}

  {{!-- ═══ ROLL RESULTS ═══ --}}
  <div class="acc-rolls">
    {{!-- Hit Roll --}}
    <div class="acc-roll-row acc-hit {{#if hit}}acc-success{{else}}acc-fail{{/if}}">
      <i class="acc-roll-icon fas {{#if hit}}fa-check{{else}}fa-times{{/if}}"></i>
      <span class="acc-roll-label">{{#if hit}}Hit!{{else}}Miss{{/if}}</span>
      <span class="acc-roll-dice"><i class="fas fa-dice-d20"></i> {{hitRoll}} / {{hitChance}}</span>
    </div>

    {{!-- Steal Outcome (only if hit) --}}
    {{#if hit}}
      {{#if stolen}}
        <div class="acc-roll-row acc-hit acc-success steal-success-row">
          <i class="acc-roll-icon fas fa-gem"></i>
          <span class="acc-roll-label">Stole <strong>{{itemName}}</strong>!</span>
          <span class="acc-roll-dice"><i class="fas fa-dice-d20"></i> {{lootRoll}} / {{lootChance}}{{#if lukBonus}} <small>({{baseChance}}+{{lukBonus}} LUK)</small>{{/if}}</span>
        </div>
      {{else}}
        {{#if noLoot}}
          <div class="acc-roll-row acc-hit acc-fail steal-noloot-row">
            <i class="acc-roll-icon fas fa-ban"></i>
            <span class="acc-roll-label">No loot available!</span>
          </div>
        {{else}}
          <div class="acc-roll-row acc-hit acc-fail steal-noloot-row">
            <i class="acc-roll-icon fas fa-hand-holding"></i>
            <span class="acc-roll-label">Found nothing to steal!</span>
          </div>
        {{/if}}
      {{/if}}
    {{else}}
      <div class="acc-roll-row steal-miss-flavor">
        <span class="acc-roll-label steal-flavor-text">Couldn't get close enough!</span>
      </div>
    {{/if}}
  </div>

  {{!-- ═══ APPLY STEAL BUTTON ═══ --}}
  {{#if stolen}}
    {{#if targetTokenId}}
      <div class="acc-apply-row">
        <button type="button" class="steal-apply-btn"
                data-target-token-id="{{targetTokenId}}"
                data-thief-token-id="{{thiefTokenId}}"
                data-item-index="{{itemIndex}}"
                data-item-uuid="{{itemUuid}}"
                data-item-name="{{itemName}}">
          <i class="fas fa-hand-sparkles"></i>
          Apply Steal — {{itemName}}
        </button>
      </div>
    {{/if}}
  {{/if}}
</div>
