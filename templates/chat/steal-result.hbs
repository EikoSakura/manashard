<div class="ms-card card-steal">
  <div class="ms-card-header">
    <div class="ms-card-portrait"><img src="{{actorImg}}" /></div>
    <div class="ms-card-identity">
      <div class="ms-card-name">{{actorName}}</div>
      <div class="ms-card-subtitle">uses <strong>{{skillName}}</strong></div>
    </div>
    <span class="ms-card-header-badge badge-icon"><i class="fas fa-hand-sparkles"></i></span>
  </div>
  <div class="ms-card-action steal">
    <div class="action-gem"></div>
    Steal
  </div>
  {{#if targetName}}
  <div class="ms-card-target">
    <span class="ms-card-target-arrow"><i class="fas fa-arrow-right"></i></span>
    <span class="ms-card-target-name">{{targetName}}</span>
  </div>
  {{/if}}
  <div class="ms-card-roll">
    <div class="ms-card-roll-row {{#if hit}}roll-hit{{else}}roll-miss{{/if}}">
      <i class="ms-card-roll-icon fas {{#if hit}}fa-check{{else}}fa-times{{/if}}"></i>
      <span class="ms-card-roll-label">{{#if hit}}Hit!{{else}}Miss{{/if}}</span>
      <div class="ms-card-roll-values">
        <span class="ms-card-roll-result"><i class="fas fa-dice-d20"></i> {{hitRoll}}</span>
        <span class="ms-card-roll-sep">/</span>
        <span class="ms-card-roll-threshold">{{hitChance}}</span>
      </div>
    </div>
    {{#if hit}}
      {{#if stolen}}
        <div class="ms-card-roll-row roll-hit">
          <i class="ms-card-roll-icon fas fa-gem"></i>
          <span class="ms-card-roll-label">Stole <strong>{{itemName}}</strong>!</span>
          <div class="ms-card-roll-values">
            <span class="ms-card-roll-result"><i class="fas fa-dice-d20"></i> {{lootRoll}}</span>
            <span class="ms-card-roll-sep">/</span>
            <span class="ms-card-roll-threshold">{{lootChance}}{{#if lukBonus}} <small>({{baseChance}}+{{lukBonus}} LUK)</small>{{/if}}</span>
          </div>
        </div>
      {{else}}
        {{#if noLoot}}
          <div class="ms-card-roll-row roll-miss">
            <i class="ms-card-roll-icon fas fa-ban"></i>
            <span class="ms-card-roll-label">No loot available!</span>
          </div>
        {{else}}
          <div class="ms-card-roll-row roll-miss">
            <i class="ms-card-roll-icon fas fa-hand-holding"></i>
            <span class="ms-card-roll-label">Found nothing to steal!</span>
          </div>
        {{/if}}
      {{/if}}
    {{else}}
      <div class="ms-card-steal-flavor">Couldn't get close enough!</div>
    {{/if}}
  </div>
  {{#if stolen}}
    {{#if targetTokenId}}
      <div class="ms-card-apply-row">
        <button type="button" class="steal-apply-btn"
                data-target-token-id="{{targetTokenId}}"
                data-thief-token-id="{{thiefTokenId}}"
                data-item-index="{{itemIndex}}"
                data-item-uuid="{{itemUuid}}"
                data-item-name="{{itemName}}">
          <i class="fas fa-hand-sparkles"></i>
          Apply Steal — {{itemName}}
        </button>
      </div>
    {{/if}}
  {{/if}}
</div>
