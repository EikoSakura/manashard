<div class="ms-card card-skill">
  {{!-- ═══ HEADER BAR ═══ --}}
  <div class="ms-card-header">
    <div class="ms-card-portrait"><img src="{{actorImg}}" /></div>
    <div class="ms-card-identity">
      <div class="ms-card-name">{{actorName}}</div>
      <div class="ms-card-subtitle">
        {{#if (eq skillType "magic")}}casts{{else}}uses{{/if}}
        <strong>{{skillName}}</strong>
      </div>
    </div>
    {{#if element}}
      <span class="ms-card-header-badge element-pip element-{{element}}">{{element}}</span>
    {{/if}}
  </div>

  {{!-- ═══ TARGET LINE ═══ --}}
  {{#if targetName}}
  <div class="ms-card-target">
    <span class="ms-card-target-arrow">&#9656;</span>
    <span class="ms-card-target-label">TARGET</span>
    <span class="ms-card-target-name">{{targetName}}</span>
  </div>
  {{/if}}

  {{!-- ═══ SKILL TYPE BADGES ═══ --}}
  <div class="ms-card-tags">
    <span class="ms-card-tag tag-type">{{skillType}}</span>
    {{#if isHealing}}
      <span class="ms-card-tag tag-type"><i class="fas fa-heart"></i> Healing</span>
    {{/if}}
    {{#if (eq targetType "aoe")}}
      <span class="ms-card-tag tag-type"><i class="fas fa-burst"></i> AoE</span>
    {{else if (eq targetType "self")}}
      <span class="ms-card-tag tag-type"><i class="fas fa-user-shield"></i> Self</span>
    {{/if}}
  </div>

  {{!-- ═══ STAT PIPS ═══ --}}
  <div class="ms-card-stat-pips">
    {{#if mpCost}}
      <div class="ms-card-stat-pip pip-mp">
        <span class="pip-label">MP</span>
        <span class="pip-value">{{mpCost}}</span>
      </div>
    {{/if}}
    {{#if range}}
      <div class="ms-card-stat-pip">
        <span class="pip-label">{{#if isMeleeSkill}}Reach{{else}}Rng{{/if}}</span>
        <span class="pip-value">{{range}}</span>
      </div>
    {{/if}}
    {{#if chantLabel}}
      <div class="ms-card-stat-pip pip-chant-{{chantKey}}">
        <span class="pip-label">Chant</span>
        <span class="pip-value">{{chantLabel}}</span>
      </div>
    {{/if}}
    {{#if showEffectMod}}
      <div class="ms-card-stat-pip">
        <span class="pip-label">Effect</span>
        <span class="pip-value">x{{effectModifier}}</span>
      </div>
    {{/if}}
  </div>

  {{!-- ═══ DESCRIPTION ═══ --}}
  {{#if description}}
    <div class="ms-card-body">
      <div class="ms-card-desc {{#unless longDescription}}scc-desc-short{{/unless}}">{{{description}}}</div>
    </div>
  {{/if}}

  {{!-- ═══ APPLY EFFECT BUTTON (buff/debuff skills) ═══ --}}
  {{#if buffDuration}}
    <div class="ms-card-apply-row">
      <button type="button" class="scc-apply-buff"
              data-buff="{{{buffRulesJson}}}">
        <i class="fas fa-shield-halved"></i> Apply Effect to Targets ({{buffDuration}} turns)
      </button>
    </div>
  {{/if}}
</div>
