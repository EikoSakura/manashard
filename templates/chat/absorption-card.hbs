<div class="ms-card card-absorb">
  <div class="ms-card-header">
    <div class="ms-card-portrait"><img src="{{actorImg}}" /></div>
    <div class="ms-card-identity">
      <div class="ms-card-name">{{actorName}}</div>
      <div class="ms-card-subtitle">absorbed</div>
    </div>
  </div>
  <div class="ms-card-action absorb">
    <div class="action-gem"></div>
    Manacite Absorbed
  </div>
  <div class="ms-card-body">
    <div class="ms-card-item-row" style="border-color: rgba(167, 139, 250, .12);">
      <div class="ms-card-item-icon" style="background: rgba(167, 139, 250, .12);">
        <img src="{{itemImg}}" alt="{{itemName}}" />
      </div>
      <div>
        <div class="ms-card-item-name" style="color: #c4a7fa;">{{itemName}}</div>
        {{#if typeBadges.length}}
        <div class="ms-card-tags" style="padding: 2px 0 0;">
          {{#each typeBadges}}<span class="ms-card-tag tag-type">{{this}}</span>{{/each}}
        </div>
        {{/if}}
      </div>
    </div>
  </div>
  {{#if stats.length}}
  <div class="ms-card-stats">
    {{#each stats}}
    <div class="ms-card-stat-cell">
      <span class="ms-card-stat-label">{{this.label}}</span>
      <span class="ms-card-stat-value">{{this.value}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}
  <div class="ms-card-confirm">
    <i class="fas fa-sun"></i> Skill permanently learned
  </div>
</div>
