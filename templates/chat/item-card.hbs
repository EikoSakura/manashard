<div class="ms-card card-item">

  {{!-- ═══ HEADER: Icon + Name + Type Badges ═══ --}}
  <div class="ms-card-header">
    <div class="ms-card-item-icon {{iconFrameClass}}">
      {{#if (eq iconFrameClass "diamond")}}
        <img src="{{itemImg}}" class="ms-card-item-icon-img ic-diamond-inner" alt="{{itemName}}" />
      {{else}}
        <img src="{{itemImg}}" class="ms-card-item-icon-img" alt="{{itemName}}" />
      {{/if}}
    </div>
    <div class="ms-card-identity">
      <div class="ms-card-name">{{itemName}}</div>
      <div class="ms-card-tags">
        {{#each typeBadges}}
          <span class="ms-card-tag">{{this}}</span>
        {{/each}}
      </div>
    </div>
  </div>

  {{!-- ═══ STATS ZONE ═══ --}}
  {{#if stats.length}}
  <div class="ms-card-stats">
    {{#each stats}}
    <div class="ms-card-stat-cell">
      <span class="ms-card-stat-label">{{this.label}}</span>
      <span class="ms-card-stat-value">{{this.value}}</span>
    </div>
    {{/each}}

    {{!-- Badges --}}
    {{#if ../badges.length}}
    <div class="ms-card-tags">
      {{#each ../badges}}
      <span class="ms-card-tag" style="background:{{this.bg}}; border-color:{{this.border}}; color:{{this.text}};">
        <span class="tag-dot" style="background:{{this.text}};"></span>{{this.label}}
      </span>
      {{/each}}
    </div>
    {{/if}}
  </div>
  {{/if}}

  {{!-- ═══ EFFECT LINE ═══ --}}
  {{#if effectLine}}
  <div class="ms-card-effect">
    <span class="ms-card-effect-icon">{{effectLine.icon}}</span>
    <span class="ms-card-effect-text">{{{effectLine.text}}}</span>
  </div>
  {{/if}}

  {{!-- ═══ DESCRIPTION ═══ --}}
  {{#if description}}
  <div class="ms-card-body">
    <div class="ms-card-desc">{{description}}</div>
  </div>
  {{/if}}

  {{!-- ═══ APPLY BUTTON ═══ --}}
  {{#if hasApply}}
  <div class="ms-card-apply-row">
    <button type="button" class="item-card-apply"
            data-apply-type="{{applyType}}"
            data-actor-id="{{actorId}}"
            data-item-id="{{itemId}}"
            {{#if applyData.targetType}}data-target-type="{{applyData.targetType}}"{{/if}}
            {{#if applyData.consumed}}data-consumed="{{applyData.consumed}}"{{/if}}
            {{#if applyData.restoreType}}data-restore-type="{{applyData.restoreType}}"{{/if}}
            {{#if applyData.restoreAmount}}data-restore-amount="{{applyData.restoreAmount}}"{{/if}}
            {{#if applyData.effectsJson}}data-effects-json='{{{applyData.effectsJson}}}'{{/if}}>
      <i class="fas {{applyIcon}}"></i>
      {{applyLabel}}
    </button>
  </div>
  {{/if}}

</div>
