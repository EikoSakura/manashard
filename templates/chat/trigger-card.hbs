<div class="ms-card card-trigger">
  <div class="ms-card-header">
    <div class="ms-card-portrait"><img src="{{actorImg}}" /></div>
    <div class="ms-card-identity">
      <div class="ms-card-name">{{actorName}}</div>
      <div class="ms-card-subtitle">triggers <strong>{{skillName}}</strong></div>
    </div>
    <span class="ms-card-header-badge badge-icon"><i class="fas fa-bolt"></i></span>
  </div>
  <div class="ms-card-action trigger">
    <div class="action-gem"></div>
    Trigger
  </div>
  {{#if skillImg}}
  <div class="ms-card-trigger-result">
    <img src="{{skillImg}}" />
    <span>{{{resultText}}}</span>
  </div>
  {{/if}}
</div>
