<div class="manashard attack-chat-card trigger-card">
  {{!-- ═══ HEADER BAR ═══ --}}
  <div class="acc-header">
    <div class="acc-portrait-frame">
      <div class="acc-portrait-diamond">
        <img src="{{actorImg}}" class="acc-portrait" />
      </div>
    </div>
    <div class="acc-header-text">
      <span class="acc-actor-name">{{actorName}}</span>
      <span class="acc-action">triggers <strong>{{skillName}}</strong></span>
    </div>
    <span class="acc-target-badge acc-target-trigger"><i class="fas fa-bolt"></i></span>
  </div>

  {{!-- ═══ SKILL ICON + NAME ═══ --}}
  {{#if skillImg}}
  <div class="acc-rolls">
    <div class="acc-roll-row acc-hit acc-success">
      <img src="{{skillImg}}" width="20" height="20" style="border:none;margin-right:6px;" />
      <span class="acc-roll-label">{{{resultText}}}</span>
    </div>
  </div>
  {{/if}}
</div>
