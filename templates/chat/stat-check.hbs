<div class="ms-card card-stat {{#if success}}sc-pass{{else}}sc-fail{{/if}} {{#if contested}}sc-contested{{/if}}" style="--sc-accent: {{statColor}}">

  {{!-- ═══ HEADER ═══ --}}
  <div class="ms-card-header">
    <div class="ms-card-portrait"><img src="{{actorImg}}" /></div>
    <div class="ms-card-identity">
      <div class="ms-card-name">{{actorName}}</div>
      <div class="ms-card-subtitle">makes a stat check</div>
    </div>
    <span class="ms-card-header-badge badge-stat" style="--sc-stat-color: {{statColor}}">{{statLabel}}</span>
  </div>

  {{!-- ═══ CONTEXT LINE ═══ --}}
  {{#if context}}
  <div class="ms-card-context-line">
    <span class="ctx-icon">&#9656;</span>
    <span>{{context}}</span>
  </div>
  {{/if}}

  {{!-- ═══ ROLL ZONE ═══ --}}
  <div class="ms-card-roll">
    <div class="ms-card-roll-row {{#if success}}roll-hit{{else}}roll-miss{{/if}}">
      <i class="ms-card-roll-icon fas fa-dice-d20"></i>
      <span class="ms-card-roll-label" style="color: {{statColor}}">{{statLabel}}</span>
      <div class="ms-card-roll-values">
        <span class="ms-card-roll-result">{{rollTotal}}</span>
        <span class="ms-card-roll-sep">/</span>
        <span class="ms-card-roll-threshold">{{threshold}}</span>
      </div>
      <span class="ms-card-outcome-badge {{#if success}}badge-pass{{else}}badge-fail{{/if}}">
        {{#if success}}PASS{{else}}FAIL{{/if}}
      </span>
    </div>
  </div>

  {{!-- ═══ CONTESTED: OPPONENT ═══ --}}
  {{#if contested}}
    <div class="ms-card-vs-divider"><span class="ms-card-vs-text">VS</span></div>

    {{!-- Opponent Header --}}
    <div class="ms-card-header">
      <div class="ms-card-portrait"><img src="{{opponentImg}}" /></div>
      <div class="ms-card-identity">
        <div class="ms-card-name">{{opponentName}}</div>
        <div class="ms-card-subtitle">responds with a stat check</div>
      </div>
      <span class="ms-card-header-badge badge-stat" style="--sc-stat-color: {{opponentStatColor}}">{{opponentStatLabel}}</span>
    </div>

    {{!-- Opponent Roll Zone --}}
    <div class="ms-card-roll">
      <div class="ms-card-roll-row {{#if opponentSuccess}}roll-hit{{else}}roll-miss{{/if}}">
        <i class="ms-card-roll-icon fas fa-dice-d20"></i>
        <span class="ms-card-roll-label" style="color: {{opponentStatColor}}">{{opponentStatLabel}}</span>
        <div class="ms-card-roll-values">
          <span class="ms-card-roll-result">{{opponentRollTotal}}</span>
          <span class="ms-card-roll-sep">/</span>
          <span class="ms-card-roll-threshold">{{opponentThreshold}}</span>
        </div>
        <span class="ms-card-outcome-badge {{#if opponentSuccess}}badge-pass{{else}}badge-fail{{/if}}">
          {{#if opponentSuccess}}PASS{{else}}FAIL{{/if}}
        </span>
      </div>
    </div>

    {{!-- Winner Banner --}}
    <div class="ms-card-winner-banner">
      <i class="fas fa-trophy"></i>
      <span><strong>{{winnerName}}</strong> wins!</span>
    </div>
  {{/if}}

  {{!-- ═══ FORMULA PANEL (right-click) ═══ --}}
  <div class="sc-formula-context">
    <div class="sc-formula-header">
      <i class="fas fa-scroll"></i>
      <span>{{actorName}} — {{statLabel}} Check</span>
    </div>

    <div class="sc-formula-section">
      <div class="sc-formula-section-label">Check Formula</div>
      <div class="sc-formula-row">
        <span class="sc-formula-label">Base {{statLabel}}</span>
        <span class="sc-formula-value">{{baseStat}}</span>
      </div>
      <div class="sc-formula-row">
        <span class="sc-formula-label">{{statLabel}} &times; 2</span>
        <span class="sc-formula-value">{{threshold}}</span>
      </div>
      {{#if checkBonus}}
      <div class="sc-formula-row">
        <span class="sc-formula-label">Check Bonus</span>
        <span class="sc-formula-value">{{#if (gt checkBonus 0)}}+{{/if}}{{checkBonus}}</span>
      </div>
      {{/if}}
      {{#if conditionalBonus}}
      <div class="sc-formula-row">
        <span class="sc-formula-label">Conditional</span>
        <span class="sc-formula-value">{{#if (gt conditionalBonus 0)}}+{{/if}}{{conditionalBonus}}</span>
      </div>
      {{#each activeCondLabels}}
      <div class="sc-formula-row sc-formula-sub">
        <span class="sc-formula-label sc-conditional-detail">↳ {{this}}</span>
      </div>
      {{/each}}
      {{/if}}
      {{#if difficultyMod}}
      <div class="sc-formula-row">
        <span class="sc-formula-label">Difficulty ({{difficultyLabel}})</span>
        <span class="sc-formula-value">{{#if (gt difficultyMod 0)}}+{{/if}}{{difficultyMod}}</span>
      </div>
      {{/if}}
      <hr class="sc-formula-divider" />
      <div class="sc-formula-row sc-formula-total">
        <span class="sc-formula-label">Threshold</span>
        <span class="sc-formula-value">{{threshold}}</span>
      </div>
      <div class="sc-formula-row sc-formula-total">
        <span class="sc-formula-label">Roll</span>
        <span class="sc-formula-value">{{rollTotal}}</span>
      </div>
    </div>

    {{#if contested}}
    <div class="sc-formula-section">
      <div class="sc-formula-section-label">{{opponentName}} — {{opponentStatLabel}} Check</div>
      <div class="sc-formula-row">
        <span class="sc-formula-label">Base {{opponentStatLabel}}</span>
        <span class="sc-formula-value">{{opponentBaseStat}}</span>
      </div>
      <div class="sc-formula-row">
        <span class="sc-formula-label">{{opponentStatLabel}} &times; 2</span>
        <span class="sc-formula-value">{{opponentThreshold}}</span>
      </div>
      {{#if opponentCheckBonus}}
      <div class="sc-formula-row">
        <span class="sc-formula-label">Check Bonus</span>
        <span class="sc-formula-value">{{#if (gt opponentCheckBonus 0)}}+{{/if}}{{opponentCheckBonus}}</span>
      </div>
      {{/if}}
      {{#if opponentDifficultyMod}}
      <div class="sc-formula-row">
        <span class="sc-formula-label">Difficulty ({{opponentDifficultyLabel}})</span>
        <span class="sc-formula-value">{{#if (gt opponentDifficultyMod 0)}}+{{/if}}{{opponentDifficultyMod}}</span>
      </div>
      {{/if}}
      <hr class="sc-formula-divider" />
      <div class="sc-formula-row sc-formula-total">
        <span class="sc-formula-label">Threshold</span>
        <span class="sc-formula-value">{{opponentThreshold}}</span>
      </div>
      <div class="sc-formula-row sc-formula-total">
        <span class="sc-formula-label">Roll</span>
        <span class="sc-formula-value">{{opponentRollTotal}}</span>
      </div>
    </div>
    {{/if}}
  </div>

  {{!-- ═══ INSPECT HINT ═══ --}}
  <div class="ms-card-inspect-hint">
    <span class="hint-key">Right-click</span>
    <span>to inspect formulas</span>
  </div>

</div>
