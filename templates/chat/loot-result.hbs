<div class="ms-card card-loot">
  <div class="ms-card-header">
    <div class="ms-card-portrait"><img src="{{defenderImg}}" /></div>
    <div class="ms-card-identity">
      <div class="ms-card-name">{{defenderName}}</div>
      <div class="ms-card-subtitle">defeated!</div>
    </div>
    <span class="ms-card-header-badge badge-icon"><i class="fas fa-gift"></i></span>
  </div>
  <div class="ms-card-action loot">
    <div class="action-gem"></div>
    Loot
  </div>
  {{#if hasEiress}}
  <div class="ms-card-loot-eiress">
    <i class="fas fa-coins"></i>
    <span class="ms-card-loot-eiress-amount">{{eiress.amount}}G deposited</span>
    {{#if (gt eiress.multiplier 1)}}
      <small class="ms-card-loot-eiress-breakdown">{{eiress.base}} &times; {{eiress.multiplier}} ({{eiress.role}})</small>
    {{/if}}
  </div>
  {{/if}}
  {{#if hasPillage}}
  <div class="ms-card-loot-section">
    <div class="ms-card-loot-section-header">
      <i class="fas fa-skull-crossbones"></i>
      <span>Pillage — {{pillage.actorName}}</span>
    </div>
    {{#if pillage.pillaged}}
      <div class="ms-card-loot-member">
        <img src="{{pillage.actorImg}}" />
        <span class="ms-card-loot-member-name">{{pillage.actorName}}</span>
        <span class="ms-card-loot-item-badge">
          <img src="{{pillage.itemImg}}" />
          {{pillage.itemName}}
        </span>
        {{#if pillage.guaranteed}}
          <span class="ms-card-loot-roll"><i class="fas fa-shield-alt"></i> Guaranteed</span>
        {{else}}
          <span class="ms-card-loot-roll"><i class="fas fa-dice-d20"></i> {{pillage.lootRoll}} / {{pillage.lootChance}}{{#if pillage.lukBonus}} <small>({{pillage.baseChance}}+{{pillage.lukBonus}} LUK)</small>{{/if}}</span>
        {{/if}}
      </div>
    {{else}}
      <div class="ms-card-loot-member">
        <img src="{{pillage.actorImg}}" />
        <span class="ms-card-loot-member-name">{{pillage.actorName}}</span>
        <span class="ms-card-loot-miss">No loot available</span>
      </div>
    {{/if}}
  </div>
  {{/if}}
  {{#if hasPartyLoot}}
  <div class="ms-card-loot-section">
    <div class="ms-card-loot-section-header">
      <i class="fas fa-users"></i>
      <span>Party Loot</span>
    </div>
    {{#each partyResults}}
      {{#if this.won}}
        <div class="ms-card-loot-member">
          <img src="{{this.actorImg}}" />
          <span class="ms-card-loot-member-name">{{this.actorName}}</span>
          <span class="ms-card-loot-item-badge">
            <img src="{{this.itemImg}}" />
            {{this.itemName}}
          </span>
          <span class="ms-card-loot-roll"><i class="fas fa-dice-d20"></i> {{this.lootRoll}} / {{this.lootChance}}{{#if this.lukBonus}} <small>({{this.baseChance}}+{{this.lukBonus}} LUK)</small>{{/if}}</span>
        </div>
      {{else}}
        <div class="ms-card-loot-member">
          <img src="{{this.actorImg}}" />
          <span class="ms-card-loot-member-name">{{this.actorName}}</span>
          <span class="ms-card-loot-miss">No drops</span>
        </div>
      {{/if}}
    {{/each}}
  </div>
  {{/if}}
  {{#if hasAwards}}
    <div class="ms-card-apply-row">
      <button type="button" class="loot-apply-btn"
              data-target-token-id="{{targetTokenId}}"
              data-target-actor-id="{{targetActorId}}"
              data-awards="{{awardsJson}}">
        <i class="fas fa-gift"></i>
        Apply All Loot
      </button>
    </div>
  {{/if}}
</div>
