<div class="ms-card card-aoe {{#if element}}element-{{element}}{{/if}}">

  {{!-- ═══ HEADER ═══ --}}
  <div class="ms-card-header">
    <div class="ms-card-portrait"><img src="{{actorImg}}" /></div>
    <div class="ms-card-identity">
      <div class="ms-card-name">{{actorName}}</div>
      <div class="ms-card-subtitle">casts <strong>{{skillName}}</strong></div>
    </div>
    {{#if (gt mpCost 0)}}<span class="ms-card-header-badge badge-mp">MP &minus;{{mpCost}}</span>{{/if}}
  </div>

  {{!-- ═══ AOE INFO LINE ═══ --}}
  <div class="ms-card-aoe-info">
    <span class="ms-card-aoe-badge"><i class="fas fa-burst"></i> {{aoeShape}}</span>
    <span class="ms-card-aoe-badge">Size {{aoeSize}}</span>
    <span class="ms-card-aoe-badge">{{hitCount}} hit / {{totalCount}} targets</span>
  </div>

  {{!-- ═══ DAMAGE TYPE / ELEMENT BADGES ═══ --}}
  <div class="ms-card-dmg-badges" style="padding: 2px 8px;">
    {{#if isBarrier}}
      <span class="ms-card-dmg-badge badge-barrier"><span class="badge-dot"></span>BARRIER</span>
    {{else if (eq damageType "none")}}
      <span class="ms-card-dmg-badge badge-none"><span class="badge-dot"></span>NONE</span>
    {{else if (eq damageType "physical")}}
      <span class="ms-card-dmg-badge badge-physical"><span class="badge-dot"></span>PHYSICAL</span>
    {{else}}
      <span class="ms-card-dmg-badge badge-magical"><span class="badge-dot"></span>MAGICAL</span>
    {{/if}}
    {{#if element}}
      <span class="ms-card-dmg-badge badge-elem elem-{{element}}"><span class="badge-dot"></span>{{upper element}}</span>
    {{else}}
      <span class="ms-card-dmg-badge badge-elem elem-neutral"><span class="badge-dot"></span>NEUTRAL</span>
    {{/if}}
  </div>

  {{!-- ═══ PER-TARGET RESULTS ═══ --}}
  {{#each targets}}
  <div class="ms-card-aoe-target {{#if this.critHit}}aoe-crit{{/if}} {{#if this.hit}}aoe-hit{{else}}aoe-miss{{/if}}" {{#if this.debugDataJson}}data-debug="{{{this.debugDataJson}}}"{{/if}}>

    {{!-- Target Header --}}
    <div class="ms-card-aoe-target-header">
      <img src="{{this.targetImg}}" class="ms-card-aoe-target-portrait" />
      <span class="ms-card-aoe-target-name">{{this.targetName}}</span>
      {{#if this.isHealing}}
        <span class="ms-card-target-badge badge-heal"><i class="fas fa-heart"></i></span>
      {{else if this.isBarrier}}
        <span class="ms-card-target-badge badge-heal"><i class="fas fa-shield-halved"></i></span>
      {{/if}}
    </div>

    {{!-- Hit Roll --}}
    {{#if this.isHealing}}
      <div class="ms-card-roll-row roll-hit roll-autohit">
        <i class="ms-card-roll-icon fas fa-heart"></i>
        <span class="ms-card-roll-label">HIT</span>
        <span class="ms-card-outcome-badge badge-hit">HIT</span>
      </div>
    {{else if this.isBarrier}}
      <div class="ms-card-roll-row roll-hit roll-autohit">
        <i class="ms-card-roll-icon fas fa-shield-halved"></i>
        <span class="ms-card-roll-label">HIT</span>
        <span class="ms-card-outcome-badge badge-hit">HIT</span>
      </div>
    {{else}}
      <div class="ms-card-roll-row {{#if this.hit}}roll-hit{{else}}roll-miss{{/if}}">
        <i class="ms-card-roll-icon fas fa-dice-d20"></i>
        <span class="ms-card-roll-label">HIT</span>
        <div class="ms-card-roll-values">
          <span class="ms-card-roll-result">{{this.hitRoll}}</span>
          <span class="ms-card-roll-sep">/</span>
          <span class="ms-card-roll-threshold">{{this.hitChance}}</span>
        </div>
        <span class="ms-card-outcome-badge {{#if this.hit}}badge-hit{{else}}badge-miss{{/if}}">
          {{#if this.hit}}HIT{{else}}MISS{{/if}}
        </span>
      </div>
    {{/if}}

    {{#if this.hit}}
      {{!-- Crit Row --}}
      {{#if this.critHit}}
        <div class="ms-card-roll-row roll-crit">
          <i class="ms-card-roll-icon fas fa-star"></i>
          <span class="ms-card-roll-label">CRIT</span>
          <div class="ms-card-roll-values">
            <span class="ms-card-roll-result">{{this.critRoll}}</span>
            <span class="ms-card-roll-sep">&le;</span>
            <span class="ms-card-roll-threshold">{{this.critChance}}</span>
          </div>
          <span class="ms-card-outcome-badge badge-crit">CRIT!</span>
        </div>
      {{/if}}

      {{!-- Block Row --}}
      {{#unless this.isHealing}}
        {{#if this.blocked}}
          <div class="ms-card-roll-row roll-block">
            <i class="ms-card-roll-icon fas fa-shield"></i>
            <span class="ms-card-roll-label">BLOCK</span>
            <div class="ms-card-roll-values">
              <span class="ms-card-roll-result">{{this.blockRoll}}</span>
              <span class="ms-card-roll-sep">/</span>
              <span class="ms-card-roll-threshold">{{this.blockChance}}</span>
            </div>
            <span class="ms-card-outcome-badge badge-block">BLOCKED</span>
          </div>
        {{/if}}
      {{/unless}}

      {{!-- Damage Display --}}
      <div class="ms-card-aoe-damage {{#if this.isHealing}}dmg-healing{{/if}} {{#if this.critHit}}dmg-crit{{/if}} {{#if (eq this.finalDamage 0)}}dmg-immune{{/if}} {{#if this.isBarrier}}dmg-barrier{{/if}}">
        <span class="ms-card-aoe-damage-label">
          {{#if (eq this.finalDamage 0)}}NO EFFECT{{else}}{{#if this.isBarrier}}BARRIER{{else}}{{#if this.isHealing}}HEAL{{else}}{{#if this.critHit}}CRIT DMG{{else}}DMG{{/if}}{{/if}}{{/if}}{{/if}}
        </span>
        <span class="ms-card-aoe-damage-value">{{#if (eq this.finalDamage 0)}}&mdash;{{else}}{{this.finalDamage}}{{/if}}</span>
      </div>

      {{!-- Modifier Notes (compact) --}}
      {{#if this.elementTierLabel}}
        <div class="ms-card-element-tier tier-{{this.elementTier}}">{{this.elementTierLabel}}</div>
      {{/if}}
      {{#if this.impairApplied}}
        <div class="ms-card-modifier acc-note-impair"><i class="fas fa-eye-slash"></i> Impair — ACC/CRIT halved</div>
      {{/if}}
      {{#if this.exposeApplied}}
        <div class="ms-card-modifier acc-note-expose"><i class="fas fa-shield-virus"></i> Expose — EVA/DEF halved</div>
      {{/if}}

      {{!-- Status Inflictions --}}
      {{#each this.statusResults}}
        {{#if this.success}}
          <div class="ms-card-status-line status-success">
            <i class="fas fa-skull-crossbones"></i>
            <span>Inflicted <strong>{{this.statusLabel}}</strong>!</span>
          </div>
        {{else}}
          <div class="ms-card-status-line status-failed">
            <i class="fas fa-shield-halved"></i>
            <span>{{this.statusLabel}} resisted ({{this.roll}} / {{this.chance}})</span>
          </div>
        {{/if}}
      {{/each}}

      {{!-- Apply Button --}}
      {{#if this.targetTokenId}}
        <div class="ms-card-apply-row">
          <button type="button" class="acc-apply-damage"
                  data-token-id="{{this.targetTokenId}}"
                  data-attacker-token-id="{{../attackerTokenId}}"
                  data-damage="{{this.finalDamage}}"
                  data-healing="{{this.isHealing}}"
                  data-barrier="{{this.isBarrier}}"
                  {{#if this.statusDataJson}}data-statuses="{{{this.statusDataJson}}}"{{/if}}>
            {{#if (eq this.finalDamage 0)}}
              <i class="fas fa-shield"></i> No Effect
            {{else if this.isBarrier}}
              <i class="fas fa-shield-halved"></i> Barrier {{this.finalDamage}} &rarr; {{this.targetName}}
            {{else if this.isHealing}}
              <i class="fas fa-heart"></i> Heal {{this.finalDamage}} &rarr; {{this.targetName}}
            {{else}}
              <i class="fas fa-crosshairs"></i> {{this.finalDamage}} dmg &rarr; {{this.targetName}}
            {{/if}}
          </button>
        </div>
      {{/if}}
    {{else}}
      {{!-- Miss state --}}
      {{#unless this.isHealing}}
        <div class="ms-card-aoe-miss-label">MISS</div>
      {{/unless}}
    {{/if}}
  </div>
  {{/each}}

  {{!-- ═══ FORMULA PANEL (right-click) ═══ --}}
  <div class="acc-formula-context">
    <div class="acc-formula-header">
      <i class="fas fa-scroll"></i>
      <span>{{actorName}} — {{skillName}} (AOE)</span>
    </div>
    <div class="acc-formula-section">
      <div class="acc-formula-section-label">Attack Formula (shared)</div>
      {{#each formulaSteps}}
        <div class="acc-formula-row">
          <span class="acc-formula-label">{{this.label}}</span>
          <span class="acc-formula-value">{{this.value}}</span>
        </div>
      {{/each}}
      {{#if chantLabel}}
        <div class="acc-formula-row">
          <span class="acc-formula-label">{{chantLabel}}</span>
          <span class="acc-formula-value">&times;{{chantModifier}}</span>
        </div>
      {{/if}}
    </div>
  </div>

</div>
