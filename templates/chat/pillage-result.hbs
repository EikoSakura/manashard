<div class="manashard attack-chat-card pillage-card">
  {{!-- ═══ HEADER BAR ═══ --}}
  <div class="acc-header">
    <div class="acc-portrait-frame">
      <div class="acc-portrait-diamond">
        <img src="{{actorImg}}" class="acc-portrait" />
      </div>
    </div>
    <div class="acc-header-text">
      <span class="acc-actor-name">{{actorName}}</span>
      <span class="acc-action">triggers <strong>Pillage</strong></span>
    </div>
    <span class="acc-target-badge acc-target-pillage"><i class="fas fa-skull-crossbones"></i></span>
  </div>

  {{!-- ═══ TARGET LINE ═══ --}}
  {{#if targetName}}
  <div class="acc-target-line">
    <i class="fas fa-arrow-right acc-target-arrow"></i>
    <span class="acc-target-name">{{targetName}}</span>
  </div>
  {{/if}}

  {{!-- ═══ RESULT ═══ --}}
  <div class="acc-rolls">
    {{#if pillaged}}
      <div class="acc-roll-row acc-hit acc-success pillage-success-row">
        <i class="acc-roll-icon fas fa-gem"></i>
        <span class="acc-roll-label">Pillaged <strong>{{itemName}}</strong>!</span>
        <span class="acc-roll-dice"><i class="fas fa-dice-d20"></i> {{lootRoll}} / {{lootChance}}{{#if lukBonus}} <small>({{baseChance}}+{{lukBonus}} LUK)</small>{{/if}}</span>
      </div>
    {{else}}
      {{#if noLoot}}
        <div class="acc-roll-row acc-hit acc-fail pillage-noloot-row">
          <i class="acc-roll-icon fas fa-ban"></i>
          <span class="acc-roll-label">No loot to pillage!</span>
        </div>
      {{else}}
        <div class="acc-roll-row acc-hit acc-fail pillage-noloot-row">
          <i class="acc-roll-icon fas fa-hand-holding"></i>
          <span class="acc-roll-label">Pillage rolls failed!</span>
        </div>
      {{/if}}
    {{/if}}
  </div>

  {{!-- ═══ APPLY PILLAGE BUTTON ═══ --}}
  {{#if pillaged}}
    {{#if targetTokenId}}
      <div class="acc-apply-row">
        <button type="button" class="pillage-apply-btn"
                data-target-token-id="{{targetTokenId}}"
                data-looter-token-id="{{looterTokenId}}"
                data-item-index="{{itemIndex}}"
                data-item-uuid="{{itemUuid}}"
                data-item-name="{{itemName}}">
          <i class="fas fa-skull-crossbones"></i>
          Apply Pillage — {{itemName}}
        </button>
      </div>
    {{/if}}
  {{/if}}
</div>
