<div class="ms-card card-consume">
  <div class="ms-card-header">
    <div class="ms-card-portrait"><img src="{{actorImg}}" /></div>
    <div class="ms-card-identity">
      <div class="ms-card-name">{{actorName}}</div>
      <div class="ms-card-subtitle">used</div>
    </div>
  </div>
  <div class="ms-card-action consume">
    <div class="action-gem"></div>
    Consumable
  </div>
  <div class="ms-card-body">
    <div class="ms-card-item-row" style="border-color: rgba(46, 204, 113, .1);">
      <div class="ms-card-item-icon" style="background: rgba(46, 204, 113, .1);">
        <img src="{{itemImg}}" alt="{{itemName}}" />
      </div>
      <div>
        <div class="ms-card-item-name">{{itemName}}</div>
        <div class="ms-card-tags" style="padding: 2px 0 0;">
          <span class="ms-card-tag tag-type">{{upper categoryLabel}}</span>
          {{#if targetName}}<span class="ms-card-tag tag-info">ON {{upper targetName}}</span>{{/if}}
        </div>
      </div>
    </div>
  </div>
  {{#if restoreAmount}}
  <div class="ms-card-stats">
    <div class="ms-card-stat-cell">
      <span class="ms-card-stat-label">RESTORES</span>
      <span class="ms-card-stat-value" style="color: {{#if (eq restoreType 'hp')}}#2ecc71{{else}}#74b9ff{{/if}};">+{{restoreAmount}} {{upper restoreType}}</span>
    </div>
    {{#if remaining}}
    <div class="ms-card-stat-cell">
      <span class="ms-card-stat-label">REMAINING</span>
      <span class="ms-card-stat-value">{{remaining}}</span>
    </div>
    {{/if}}
  </div>
  {{/if}}
  {{#unless applied}}
  <div class="ms-card-apply-row">
    <button type="button" class="con-apply-btn"
            data-target-token-id="{{targetTokenId}}"
            data-user-actor-id="{{userActorId}}"
            data-item-id="{{itemId}}"
            data-restore-type="{{restoreType}}"
            data-restore-amount="{{restoreAmount}}"
            data-consumed="{{consumed}}">
      <i class="fas fa-flask"></i> Apply
    </button>
  </div>
  {{else}}
  <div class="ms-card-confirm">
    <i class="fas fa-check"></i> {{appliedSummary}}
  </div>
  {{/unless}}
</div>
