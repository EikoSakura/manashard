  {{!-- ═══ Skills ═══ --}}
  <div class="combat-section">
    <h3><i class="fas fa-magic-wand-sparkles"></i> Skills
      {{#if allActiveSkills.length}}<span class="section-count-badge">{{allActiveSkills.length}}</span>{{/if}}
    </h3>
    <div class="skill-card-grid">

      {{#each allActiveSkills}}
      <div class="skill-grid-card {{this.skillType}} {{#if this._isTaught}}taught{{/if}}" data-item-id="{{this.id}}">
