      <div class="adv-bar-head">
        <span class="adv-bar-lbl mp">MP</span>
        <span class="adv-bar-val">
          <input type="number" name="system.stats.mp.value" value="{{system.stats.mp.value}}" min="0" data-dtype="Number" class="adv-bar-cur" />
          <span class="adv-bar-sep">/</span>
          <input type="number" name="system.stats.mp.max" value="{{system.stats.mp.max}}" min="0" data-dtype="Number" class="adv-bar-max" />
        </span>
      </div>
      <div class="adv-bar-track mp">
        <div class="adv-bar-fill mp" style="width: {{#if system.stats.mp.max}}{{math system.stats.mp.value "/" system.stats.mp.max "*" 100}}%{{else}}0%{{/if}}"></div>
      </div>
