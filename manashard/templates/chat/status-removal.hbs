<div class="manashard status-removal-card removal-{{source}}">

  {{!-- ═══ HEADER ═══ --}}
  <div class="acc-header">
    <div class="acc-portrait-frame">
      <div class="acc-portrait-diamond">
        <img src="{{actorImg}}" class="acc-portrait" />
      </div>
    </div>
    <div class="acc-header-info">
      <div class="acc-actor-name">{{actorName}}</div>
      <div class="acc-action-line">
        {{#if (eq source "expired")}}
          status effects wore off
        {{else if (eq source "cleansed")}}
          statuses cleansed
        {{else if (eq source "shattered")}}
          Frozen shattered!
        {{/if}}
      </div>
    </div>
  </div>

  {{!-- ═══ STATUS LIST ═══ --}}
  <div class="src-body">
    {{#each statuses}}
    <div class="src-status-line">
      <i class="{{this.icon}}"></i>
      <span class="src-status-label">{{this.label}}</span>
      <span class="src-status-tag">{{this.tag}}</span>
    </div>
    {{/each}}
  </div>

  {{!-- ═══ SOURCE INDICATOR ═══ --}}
  <div class="src-source-bar">
    <div class="src-source-icon">
      {{#if (eq source "expired")}}
        <i class="fas fa-hourglass-end"></i>
      {{else if (eq source "cleansed")}}
        <i class="fas fa-hand-sparkles"></i>
      {{else if (eq source "shattered")}}
        <i class="fas fa-snowflake"></i>
      {{/if}}
    </div>
    <span>
      {{#if (eq source "expired")}}
        Duration expired
      {{else if (eq source "cleansed")}}
        Cleansed by item
      {{else if (eq source "shattered")}}
        Ice shattered by attack
      {{/if}}
    </span>
  </div>
</div>
